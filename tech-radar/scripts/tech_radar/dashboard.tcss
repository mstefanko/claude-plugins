Screen {
    layout: vertical;
    overflow: hidden;
}

#header-bar {
    height: 1;
    width: 100%;
    background: $primary;
    color: $text;
    text-style: bold;
    padding: 0 2;
}

#tab-bar {
    height: 3;
    width: 100%;
}

#search-input {
    display: none;
    height: 1;
    width: 100%;
    margin: 0 1;
}

#search-input.visible {
    display: block;
}

#content-area {
    width: 100%;
    height: 1fr;
}

#main-table {
    width: 2fr;
    height: 100%;
    scrollbar-gutter: stable;
}

#detail {
    width: 1fr;
    height: 100%;
    border-left: tall $primary;
    padding: 1 2;
    overflow-y: auto;
}

DataTable > .datatable--header {
    background: $primary-darken-2;
    color: $text;
    text-style: bold;
}

DataTable > .datatable--cursor {
    background: $primary-lighten-1;
}

.status-watching { color: $warning; }
.status-tested   { color: $success; }
.status-rejected { color: $error; }
.status-adopted  { color: $success; text-style: bold; }

.stale-green  { color: $success; }
.stale-yellow { color: $warning; }
.stale-red    { color: $error; text-style: bold; }

.detail-heading {
    color: $text-muted;
    text-style: bold;
    margin-top: 1;
}

.detail-verdict {
    margin: 0 0 1 0;
}

AnnotationModal {
    align: center middle;
    width: 60;
    height: auto;
    max-height: 80%;
    border: thick $primary;
    padding: 1 2;
}

AnnotationModal TextArea {
    height: 4;
    margin: 1 0;
}
