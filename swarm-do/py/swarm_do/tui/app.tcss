Screen {
    layout: vertical;
}

Vertical {
    height: 1fr;
}

#logo {
    padding: 0 1;
    height: 6;
}

#banner, #target, #hash, #burn {
    padding: 0 1;
    height: 1;
}

DataTable {
    height: 1fr;
}

#pipeline-workbench {
    height: 1fr;
}

#pipeline-main {
    height: 2fr;
}

#pipeline-gallery {
    width: 36;
    border: solid $primary;
}

#presets {
    width: 34;
    border: solid $primary;
}

#stage-rows {
    width: 50;
    border: solid $primary;
}

#preview, #stage-inspector {
    width: 1fr;
    border: solid $primary;
    padding: 1;
}

#validation-rail {
    height: 10;
    border: solid $primary;
    padding: 1;
}

StatusBar {
    height: 1;
    background: $panel;
    color: $text;
    padding: 0 1;
}

#modal {
    width: 70;
    height: auto;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
}

.modal-title {
    text-style: bold;
    margin-bottom: 1;
}

.buttons {
    height: auto;
    margin-top: 1;
}
