Screen {
    layout: vertical;
    background: $background;
    color: $text;
}

* {
    scrollbar-color: $primary 35%;
    scrollbar-color-hover: $primary 80%;
    scrollbar-color-active: $primary;
    scrollbar-background: $surface-darken-1;
    scrollbar-background-hover: $surface-darken-1;
    scrollbar-background-active: $surface-darken-1;
    scrollbar-size-vertical: 1;
}

Vertical {
    height: 1fr;
}

Header {
    background: $background;
    color: $text;
}

Footer {
    background: transparent;
    color: $text-muted;
}

#logo {
    padding: 0 1;
    height: 6;
    background: $background;
}

AppChrome {
    height: 2;
    background: $panel;
    color: $text;
    padding: 0 1;
}

#dashboard-top {
    height: 6;
}

#profile-summary, #event-strip, #outcome-summary {
    width: 1fr;
    border: solid $primary;
    padding: 1;
}

#banner, #target, #hash, #burn, #settings-title, #settings-warning, #dashboard-graph-title, #queue-title {
    padding: 0 1;
    height: 1;
}

#dashboard-graph-title {
    background: $surface 65%;
    color: $text;
}

#queue-title {
    color: $text-muted;
}

DataTable {
    height: 1fr;
    background: $surface 65%;
    color: $text;
}

DataTable > .datatable--header {
    background: $panel;
    color: $text-success;
}

DataTable > .datatable--cursor,
DataTable:focus > .datatable--cursor {
    background: $primary 30%;
    color: $text;
}

#inflight {
    height: 4;
}

ListView {
    background: $surface 65%;
}

ListItem {
    color: $text-muted;
}

ListItem.-highlight,
ListItem.--highlight,
ListView:focus > ListItem.-highlight {
    background: $panel;
    color: $text;
}

Input, Select {
    background: $surface;
    color: $text;
}

Input:focus, Select:focus {
    border: solid $accent;
}

#pipeline-workbench {
    height: 1fr;
}

#pipeline-main {
    height: 1fr;
}

#pipeline-gallery {
    width: 42;
    border: solid $primary;
}

#pipeline-gallery ListItem {
    height: auto;
    min-height: 4;
    padding: 0 1;
    border-bottom: solid $surface-lighten-1;
}

#pipeline-gallery > ListItem.-highlight,
#pipeline-gallery > ListItem.--highlight,
#pipeline-gallery:focus > ListItem.-highlight {
    background: $panel;
    color: $text;
    border-left: thick $accent;
}

#pipeline-gallery .preset-row {
    width: 1fr;
    height: auto;
}

#pipeline-content {
    width: 1fr;
}

#preset-workbench {
    height: 1fr;
}

#preset-content {
    width: 1fr;
}

#preset-tabs {
    height: 1fr;
}

#preset-overview, #preset-policy-help {
    padding: 1;
    overflow-y: auto;
}

#preset-overview {
    background: $surface 45%;
}

#preset-routing, #preset-policy {
    height: 1fr;
}

#pipeline-details {
    height: 10;
}

#presets {
    width: 34;
    border: solid $primary;
}

#preset-profile {
    width: 1fr;
}

#pipeline-graph, #preset-board, #dashboard-graph {
    width: 1fr;
    height: 1fr;
    border: solid $primary;
    padding: 1;
    overflow-x: auto;
    overflow-y: auto;
}

#dashboard-graph {
    height: 4fr;
    max-height: 26;
}

#inflight {
    height: 1fr;
    min-height: 4;
}

.pipeline-board {
    layout: vertical;
}

.pipeline-board-text {
    width: 1fr;
    height: auto;
    padding: 0 1;
}

.layer-column {
    width: 100%;
    height: auto;
    margin-bottom: 1;
}

.layer-flow-gutter {
    width: 5;
    min-height: 3;
    height: auto;
    text-style: bold;
    color: $accent;
    padding: 0 1 0 0;
}

.layer-card-row {
    width: 1fr;
    height: auto;
}

.join-bridge {
    width: 1fr;
    height: auto;
    margin: 0 0 1 5;
    padding: 0 1;
    color: $warning;
    text-style: bold;
    border-left: thick $warning;
}

.output-bridge {
    width: 1fr;
    height: auto;
    margin: 0 0 1 5;
    padding: 0 1;
    color: $success;
    text-style: bold;
    border-left: thick $success;
}

.stage-card {
    width: 1fr;
    min-height: 3;
    height: auto;
    border: solid $primary;
    padding: 0 1;
    margin-right: 1;
}

.stage-card:focus {
    border: solid $accent;
}

.stage-card--selected {
    border: solid $accent;
    text-style: bold;
}

.stage-card--agents {
    border-left: thick $primary;
}

.stage-card--provider {
    border-left: thick $warning;
}

.stage-card--fanout {
    border-top: solid $primary;
}

.stage-card--terminal {
    border-left: thick $success;
}

.stage-card--dirty {
    color: $warning;
}

.stage-card--critical {
    background: $panel;
}

.stage-card--warning {
    color: $warning;
}

.stage-card--running {
    text-style: italic;
}

.stage-card--failed {
    color: $error;
    border: solid $error;
}

.stage-card--queued {
    color: $text;
}

.stage-card--done {
    color: $success;
}

.stage-badge {
    text-style: bold;
}

.join-badge {
    height: auto;
    color: $warning;
    text-style: bold;
    margin-bottom: 1;
}

#preview {
    width: 1fr;
    height: 1fr;
    border: solid $primary;
    padding: 1;
    overflow-y: auto;
}

#stage-inspector {
    width: 1fr;
    border: solid $primary;
    padding: 1;
    overflow-y: auto;
}

#pipeline-graph:focus, #preset-board:focus, #stage-inspector:focus {
    border: heavy $accent;
}

#validation-rail {
    width: 2fr;
    height: 100%;
    border: solid $primary;
    padding: 1;
    overflow-y: auto;
}

StatusBar {
    height: 1;
    background: $panel;
    color: $text;
    padding: 0 1;
}

#modal {
    width: 70;
    height: auto;
    border: thick $primary;
    background: $surface;
    padding: 1 2;
}

.modal-title {
    text-style: bold;
    margin-bottom: 1;
}

.buttons {
    height: auto;
    margin-top: 1;
}
