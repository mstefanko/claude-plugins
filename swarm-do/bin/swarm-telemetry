#!/usr/bin/env bash
# swarm-telemetry — Python-dispatch entrypoint. Sources python-bootstrap.sh,
# then execs python3 -m swarm_do.telemetry.cli. All subcommands are native
# Python as of Phase 3; the legacy bash implementation has been deleted.
set -euo pipefail

# shellcheck source=_lib/python-bootstrap.sh
source "$(dirname "${BASH_SOURCE[0]}")/_lib/python-bootstrap.sh"

exec python3 -m swarm_do.telemetry.cli "$@"
