#!/usr/bin/env bash
# swarm-telemetry — thin shim that delegates to swarm_do.telemetry.cli.
# The legacy bash implementation remains at ./swarm-telemetry.legacy and is invoked by cli.py.
set -euo pipefail

# shellcheck source=_lib/python-bootstrap.sh
source "$(dirname "${BASH_SOURCE[0]}")/_lib/python-bootstrap.sh"

exec python3 -m swarm_do.telemetry.cli "$@"
