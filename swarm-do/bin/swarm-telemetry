#!/usr/bin/env bash
# swarm-telemetry — read-only reporter for the swarm-do telemetry ledgers.
#
# Usage:
#   swarm-telemetry query <sql>
#   swarm-telemetry report [--since Nd] [--role R] [--bucket K]
#   swarm-telemetry dump <ledger>
#   swarm-telemetry validate [<ledger>]
#   swarm-telemetry sample-for-adjudication --count N [--since Nd] [--output-root PATH]
#   swarm-telemetry --test
#   swarm-telemetry -h | --help
#
# Subcommands:
#   query <sql>       Load all four JSONL ledgers into sqlite3 :memory: and execute SQL.
#                     Tables: runs, findings, outcomes, adjudications.
#   report            Stratified markdown report from runs.jsonl.
#                     --since Nd  filter to last N days (default: all time)
#                     --role R    filter to a specific role (default: all roles)
#                     --bucket K  stratify by: role | complexity | phase_kind | risk_tag
#                                 (default: role)
#   dump <ledger>     Pretty-print a ledger as a JSON array (jq -s .).
#                     ledger: runs | findings | outcomes | adjudications
#   validate          Validate every row in every ledger against the shipped JSON schemas.
#                     Exits 1 if any row fails; 0 if all rows pass (or ledger absent/empty).
#   sample-for-adjudication
#                     Pick stratified random sample of findings without adjudication rows.
#                     --count N   number of findings to sample (required)
#                     --since Nd  filter findings within last N days (default: all time)
#                     --output-root PATH  preferred phase0 output root (default: ~/.swarm/phase0/runs)
#
# Environment:
#   CLAUDE_PLUGIN_DATA   base data directory; telemetry lives at $CLAUDE_PLUGIN_DATA/telemetry/
#                        If unset, swarm-telemetry uses the default:
#                        ~/.claude/plugin-data/mstefanko-plugins/swarm-do
#   SWARM_PHASE0_ROOT    preferred root for sample-for-adjudication output. If unset,
#                        sampler prefers ~/.swarm/phase0/runs and falls back to plugin data.
#   SWARM_TELEMETRY_NOW  optional ISO-8601 UTC timestamp override for deterministic tests.
#
# Fail-open: validate and dump print warnings for absent/empty ledgers and continue.
# query and report die on missing CLAUDE_PLUGIN_DATA or missing runs.jsonl.

set -euo pipefail

_SELF="swarm-telemetry"
_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

die() { echo "${_SELF}: $*" >&2; exit 1; }

usage() {
  cat <<'EOF'
swarm-telemetry — read-only reporter for swarm-do telemetry ledgers.

Usage:
  swarm-telemetry query <sql>
  swarm-telemetry report [--since Nd] [--role R] [--bucket K]
  swarm-telemetry dump <ledger>
  swarm-telemetry validate [<ledger>]
  swarm-telemetry sample-for-adjudication --count N [--since Nd] [--output-root PATH]
  swarm-telemetry join-outcomes [--since Nd] [--repo PATH] [--dry-run]
  swarm-telemetry --test
  swarm-telemetry -h | --help

Subcommands:
  query <sql>       Execute SQL against in-memory sqlite3 loaded from all five ledgers.
  report            Stratified markdown report (role/complexity/phase_kind/risk_tag).
  dump <ledger>     Pretty-print ledger as JSON array.
  validate          Validate every ledger row against the shipped JSON schemas.
  sample-for-adjudication
                    Pick stratified random sample of findings without adjudication rows.
  join-outcomes     Correlate findings with post-merge maintainer actions; append to finding_outcomes.jsonl.

Options for report:
  --since Nd      Filter to last N days (e.g. --since 30d)
  --role R        Filter to role R
  --bucket K      Stratify by: role | complexity | phase_kind | risk_tag  (default: role)

Options for sample-for-adjudication:
  --count N       Number of findings to sample (required)
  --since Nd      Filter findings within last N days (default: all time)
  --output-root P Preferred output root (default: ~/.swarm/phase0/runs, with plugin-data fallback)

Options for join-outcomes:
  --since Nd      Scan merges within the last N days (default: 30d)
  --repo PATH     Path to git repo (default: git rev-parse --show-toplevel)
  --dry-run       Print rows that would be appended; do not write anything

Ledger names: runs | findings | outcomes | adjudications | finding_outcomes
EOF
}

_resolve_telemetry_dir() {
  local base="${CLAUDE_PLUGIN_DATA:-${HOME}/.claude/plugin-data/mstefanko-plugins/swarm-do}"
  echo "${base}/telemetry"
}

_resolve_ledger() {
  local name="$1"
  case "$name" in
    runs|findings|outcomes|adjudications|finding_outcomes) ;;
    *) die "unknown ledger '$name' — must be one of: runs findings outcomes adjudications finding_outcomes";;
  esac
  local dir
  dir="$(_resolve_telemetry_dir)"
  echo "${dir}/${name}.jsonl"
}

_resolve_phase0_root() {
  if [[ -n "${SWARM_PHASE0_ROOT:-}" ]]; then
    echo "${SWARM_PHASE0_ROOT}"
  else
    echo "${HOME}/.swarm/phase0/runs"
  fi
}

_resolve_phase0_fallback_root() {
  local base="${CLAUDE_PLUGIN_DATA:-${HOME}/.claude/plugin-data/mstefanko-plugins/swarm-do}"
  echo "${base}/phase0/runs"
}

_schema_candidates_for_ledger() {
  local name="$1"
  local schema_dir="${_SCRIPT_DIR}/../schemas/telemetry"
  case "$name" in
    runs)
      printf '%s\n' "${schema_dir}/runs.schema.json"
      ;;
    findings)
      printf '%s\n%s\n' \
        "${schema_dir}/findings.v2.schema.json" \
        "${schema_dir}/findings.schema.json"
      ;;
    outcomes)
      printf '%s\n' "${schema_dir}/outcomes.schema.json"
      ;;
    adjudications)
      printf '%s\n%s\n' \
        "${schema_dir}/adjudications.v2.schema.json" \
        "${schema_dir}/adjudications.schema.json"
      ;;
    finding_outcomes)
      printf '%s\n' "${schema_dir}/finding_outcomes.schema.json"
      ;;
    *)
      die "unknown ledger '$name' — must be one of: runs findings outcomes adjudications finding_outcomes"
      ;;
  esac
}

# ---------------------------------------------------------------------------
# Subcommand: dump
# ---------------------------------------------------------------------------

_cmd_dump() {
  local ledger="${1:-}"
  [[ -n "$ledger" ]] || die "dump requires a ledger name (runs|findings|outcomes|adjudications)"
  local path
  path="$(_resolve_ledger "$ledger")"
  if [[ ! -f "$path" || ! -s "$path" ]]; then
    echo "[]"
    return 0
  fi
  jq -s '.' "$path"
}

# ---------------------------------------------------------------------------
# Subcommand: validate
# ---------------------------------------------------------------------------

_validate_ledger() {
  local name="$1" path="$2"
  local row_num=0 fail_count=0 bad_json=0
  local schema_path
  local schema_paths=()

  if [[ ! -f "$path" ]]; then
    echo "${_SELF}: validate: $name — ledger absent (skipped)" >&2
    return 0
  fi
  if [[ ! -s "$path" ]]; then
    echo "${_SELF}: validate: $name — ledger empty (skipped)" >&2
    return 0
  fi

  while IFS= read -r schema_path; do
    [[ -n "$schema_path" ]] || continue
    [[ -f "$schema_path" ]] || die "validate: schema file missing for ${name}: ${schema_path}"
    schema_paths+=("$schema_path")
  done < <(_schema_candidates_for_ledger "$name")

  python3 - "$name" "$path" "${schema_paths[@]}" <<'PYEOF'
import datetime
import json
import os
import re
import sys

name = sys.argv[1]
path = sys.argv[2]
schema_paths = sys.argv[3:]

schemas = []
for schema_path in schema_paths:
    with open(schema_path, "r", encoding="utf-8") as f:
        schemas.append((schema_path, json.load(f)))

row_num = 0
fail_count = 0
bad_json = 0

def py_type_name(value):
    if value is None:
        return "null"
    if isinstance(value, bool):
        return "boolean"
    if isinstance(value, int):
        return "integer"
    if isinstance(value, float):
        return "number"
    if isinstance(value, str):
        return "string"
    if isinstance(value, list):
        return "array"
    if isinstance(value, dict):
        return "object"
    return type(value).__name__

def matches_type(value, schema_type):
    if schema_type == "null":
        return value is None
    if schema_type == "string":
        return isinstance(value, str)
    if schema_type == "boolean":
        return isinstance(value, bool)
    if schema_type == "integer":
        return isinstance(value, int) and not isinstance(value, bool)
    if schema_type == "number":
        return (isinstance(value, int) and not isinstance(value, bool)) or isinstance(value, float)
    if schema_type == "array":
        return isinstance(value, list)
    if schema_type == "object":
        return isinstance(value, dict)
    return False

def is_number(value):
    return (isinstance(value, int) and not isinstance(value, bool)) or isinstance(value, float)

def parse_datetime(value):
    try:
        return datetime.datetime.fromisoformat(value.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None

def validate_value(value, schema, json_path="$"):
    errors = []

    schema_type = schema.get("type")
    if schema_type is not None:
        allowed_types = schema_type if isinstance(schema_type, list) else [schema_type]
        if not any(matches_type(value, candidate) for candidate in allowed_types):
            allowed = "|".join(str(candidate) for candidate in allowed_types)
            return [f"{json_path}: expected type {allowed}, got {py_type_name(value)}"]

    if value is None:
        return errors

    if "enum" in schema and value not in schema["enum"]:
        errors.append(f"{json_path}: expected one of {schema['enum']}, got {value!r}")

    if "pattern" in schema and isinstance(value, str):
        if re.fullmatch(schema["pattern"], value) is None:
            errors.append(f"{json_path}: value {value!r} does not match /{schema['pattern']}/")

    if schema.get("format") == "date-time" and isinstance(value, str):
        if parse_datetime(value) is None:
            errors.append(f"{json_path}: value {value!r} is not a valid date-time")

    if "minimum" in schema and is_number(value) and value < schema["minimum"]:
        errors.append(f"{json_path}: value {value!r} is less than minimum {schema['minimum']}")

    if "maximum" in schema and is_number(value) and value > schema["maximum"]:
        errors.append(f"{json_path}: value {value!r} is greater than maximum {schema['maximum']}")

    if isinstance(value, dict):
        properties = schema.get("properties", {})
        for required in schema.get("required", []):
            if required not in value:
                errors.append(f"{json_path}: missing required property {required!r}")

        if schema.get("additionalProperties") is False:
            for key in value.keys():
                if key not in properties:
                    errors.append(f"{json_path}: unexpected property {key!r}")

        for key, child_schema in properties.items():
            if key in value:
                errors.extend(validate_value(value[key], child_schema, f"{json_path}.{key}"))

    if isinstance(value, list) and "items" in schema:
        for idx, item in enumerate(value):
            errors.extend(validate_value(item, schema["items"], f"{json_path}[{idx}]"))

    return errors

with open(path, "r", encoding="utf-8") as f:
    for line in f:
        row_num += 1
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError as exc:
            print(f"  FAIL row {row_num}: JSON parse error in {name}.jsonl: {exc}", file=sys.stderr)
            bad_json += 1
            fail_count += 1
            continue

        validation_errors = []
        for schema_path, schema in schemas:
            errors = validate_value(obj, schema)
            if not errors:
                validation_errors = []
                break
            validation_errors.append((schema_path, errors))

        if validation_errors:
            fail_count += 1
            best_schema_path, best_errors = min(validation_errors, key=lambda item: len(item[1]))
            print(
                f"  FAIL row {row_num} in {name}.jsonl: schema mismatch against {os.path.basename(best_schema_path)}: {best_errors[0]}",
                file=sys.stderr,
            )
            for extra in best_errors[1:3]:
                print(f"    {extra}", file=sys.stderr)

if fail_count == 0:
    print(f"  OK  {name}.jsonl — {row_num} row(s) valid", file=sys.stderr)
else:
    print(
        f"  FAIL {name}.jsonl — {fail_count} of {row_num} row(s) failed ({bad_json} JSON parse error(s))",
        file=sys.stderr,
    )

sys.exit(min(fail_count, 255))
PYEOF
  return "$?"
}

_cmd_validate() {
  local target_ledger="${1:-}"
  local tel_dir
  tel_dir="$(_resolve_telemetry_dir)"
  local total_fail=0

  command -v python3 >/dev/null 2>&1 || die "validate requires python3"

  echo "${_SELF}: validate — checking ledgers in ${tel_dir}" >&2

  _run_validation() {
    local name="$1"
    local path="${tel_dir}/${name}.jsonl"
    _validate_ledger "$name" "$path" || (( total_fail += $? )) || true
  }

  if [[ -n "$target_ledger" ]]; then
    case "$target_ledger" in
      runs)             _run_validation runs             ;;
      findings)         _run_validation findings         ;;
      outcomes)         _run_validation outcomes         ;;
      adjudications)    _run_validation adjudications    ;;
      finding_outcomes) _run_validation finding_outcomes ;;
      *) die "unknown ledger '$target_ledger' — must be one of: runs findings outcomes adjudications finding_outcomes";;
    esac
  else
    _run_validation runs
    _run_validation findings
    _run_validation outcomes
    _run_validation adjudications
    _run_validation finding_outcomes
  fi

  if [[ "$total_fail" -eq 0 ]]; then
    echo "${_SELF}: validate — all ledgers OK" >&2
    return 0
  else
    echo "${_SELF}: validate — FAILED (${total_fail} validation error(s))" >&2
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Subcommand: query
# ---------------------------------------------------------------------------

_cmd_query() {
  local sql="${1:-}"
  [[ -n "$sql" ]] || die "query requires a SQL argument"
  command -v python3 >/dev/null 2>&1 || die "query requires python3"
  command -v jq >/dev/null 2>&1 || die "query requires jq"

  local tel_dir
  tel_dir="$(_resolve_telemetry_dir)"

  python3 - "$tel_dir" "$sql" <<'PYEOF'
import sys, json, sqlite3, os

tel_dir = sys.argv[1]
sql     = sys.argv[2]

conn = sqlite3.connect(":memory:")
conn.row_factory = sqlite3.Row

LEDGER_COLS = {
    "runs": [
        "run_id", "timestamp_start", "timestamp_end", "backend", "model", "effort",
        "prompt_bundle_hash", "config_hash", "role", "phase_kind", "phase_complexity",
        "issue_id", "repo", "base_sha", "head_sha", "diff_size_bytes", "input_tokens",
        "cached_input_tokens", "output_tokens", "estimated_cost_usd", "wall_clock_seconds",
        "tool_call_count", "cap_hit", "budget_breach", "schema_ok", "exit_code",
        "setting_source", "writer_status", "review_verdict", "last_429_at",
        "risk_tags",  # stored as JSON text
    ],
    "findings": [
        "finding_id", "run_id", "timestamp", "role", "issue_id", "severity",
        "category", "summary", "file_path", "line_start", "line_end", "schema_ok",
        "stable_finding_hash_v1", "duplicate_cluster_id", "short_summary",
    ],
    "outcomes": [
        "outcome_id", "issue_id", "timestamp", "writer_run_id", "review_run_id",
        "verdict", "schema_ok",
    ],
    "adjudications": [
        "adjudication_id", "outcome_id", "issue_id", "timestamp", "adjudicator",
        "decision", "schema_ok",
    ],
    "finding_outcomes": [
        "finding_outcome_id", "finding_id", "observed_at", "maintainer_action",
        "followup_ref", "time_to_action_hours", "time_to_fix_hours",
        "recurrence_of", "schema_ok",
    ],
}

def load_ledger(name, cols):
    path = os.path.join(tel_dir, f"{name}.jsonl")
    if not os.path.isfile(path) or os.path.getsize(path) == 0:
        return []
    rows = []
    with open(path) as f:
        for lineno, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError as e:
                print(f"swarm-telemetry: query: {name}.jsonl line {lineno} parse error: {e}", file=sys.stderr)
                continue
            # Serialize array/object fields to JSON text for SQLite
            row = {}
            for col in cols:
                val = obj.get(col)
                if isinstance(val, (list, dict)):
                    val = json.dumps(val)
                row[col] = val
            rows.append(row)
    return rows

for tbl, cols in LEDGER_COLS.items():
    col_defs = ", ".join(f'"{c}" TEXT' for c in cols)
    conn.execute(f'CREATE TABLE "{tbl}" ({col_defs})')
    rows = load_ledger(tbl, cols)
    if rows:
        placeholders = ", ".join("?" for _ in cols)
        col_names    = ", ".join(f'"{c}"' for c in cols)
        conn.executemany(
            f'INSERT INTO "{tbl}" ({col_names}) VALUES ({placeholders})',
            [[r.get(c) for c in cols] for r in rows]
        )
conn.commit()

try:
    cur = conn.execute(sql)
    if cur.description is None:
        conn.commit()
        sys.exit(0)
    headers = [d[0] for d in cur.description]
    print("\t".join(headers))
    for row in cur.fetchall():
        print("\t".join("" if v is None else str(v) for v in row))
except sqlite3.Error as e:
    print(f"swarm-telemetry: query error: {e}", file=sys.stderr)
    sys.exit(1)
PYEOF
}

# ---------------------------------------------------------------------------
# Subcommand: report
# ---------------------------------------------------------------------------

_cmd_report() {
  local since_days="" filter_role="" bucket="role"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since) since_days="${2:-}"; shift 2;;
      --role)  filter_role="${2:-}"; shift 2;;
      --bucket) bucket="${2:-}"; shift 2;;
      *) die "report: unknown option '$1'";;
    esac
  done

  case "$bucket" in
    role|complexity|phase_kind|risk_tag) ;;
    *) die "report: --bucket must be one of: role complexity phase_kind risk_tag";;
  esac

  local runs_path
  runs_path="$(_resolve_ledger "runs")"

  if [[ ! -f "$runs_path" || ! -s "$runs_path" ]]; then
    die "report: runs.jsonl absent or empty at ${runs_path} — no data to report"
  fi

  command -v python3 >/dev/null 2>&1 || die "report requires python3"
  command -v jq >/dev/null 2>&1 || die "report requires jq"

  python3 - "$runs_path" "$since_days" "$filter_role" "$bucket" <<'PYEOF'
import os
import sys, json, datetime, collections, math

RUNS_PATH   = sys.argv[1]
SINCE_DAYS  = sys.argv[2]   # "" means all time
FILTER_ROLE = sys.argv[3]   # "" means all roles
BUCKET      = sys.argv[4]   # role | complexity | phase_kind | risk_tag

def parse_ts(s):
    if not s:
        return None
    try:
        return datetime.datetime.fromisoformat(s.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None

def resolve_now():
    override = os.environ.get("SWARM_TELEMETRY_NOW", "").strip()
    if not override:
        return datetime.datetime.now(datetime.timezone.utc)
    parsed = parse_ts(override)
    if parsed is None:
        print(f"swarm-telemetry: report: invalid SWARM_TELEMETRY_NOW '{override}'", file=sys.stderr)
        sys.exit(1)
    return parsed

# ---------------------------------------------------------------------------
# Parse cutoff timestamp
# ---------------------------------------------------------------------------
now = resolve_now()

cutoff = None
if SINCE_DAYS:
    n_str = SINCE_DAYS.rstrip("d").strip()
    try:
        n = int(n_str)
        cutoff = now - datetime.timedelta(days=n)
    except ValueError:
        print(f"swarm-telemetry: report: invalid --since value '{SINCE_DAYS}' — expected Nd (e.g. 30d)", file=sys.stderr)
        sys.exit(1)

# ---------------------------------------------------------------------------
# Load runs
# ---------------------------------------------------------------------------
rows = []
with open(RUNS_PATH) as f:
    for lineno, line in enumerate(f, 1):
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
        except json.JSONDecodeError as e:
            print(f"swarm-telemetry: report: runs.jsonl line {lineno} parse error: {e} — skipping", file=sys.stderr)
            continue
        rows.append(obj)

# ---------------------------------------------------------------------------
# Apply filters
# ---------------------------------------------------------------------------
filtered = []
excluded_window = 0
excluded_role   = 0

for r in rows:
    ts = parse_ts(r.get("timestamp_start") or r.get("timestamp_end"))
    if cutoff and ts and ts < cutoff:
        excluded_window += 1
        continue
    role = r.get("role", "")
    if FILTER_ROLE and role != FILTER_ROLE:
        excluded_role += 1
        continue
    filtered.append(r)

# ---------------------------------------------------------------------------
# Bucket assignment — NEVER global means; always stratify
# ---------------------------------------------------------------------------
def get_bucket_keys(row):
    """Return list of bucket keys for this row (list to handle risk_tag explosion)."""
    if BUCKET == "role":
        return [row.get("role") or "(none)"]
    elif BUCKET == "complexity":
        return [row.get("phase_complexity") or "(none)"]
    elif BUCKET == "phase_kind":
        return [row.get("phase_kind") or "(none)"]
    elif BUCKET == "risk_tag":
        tags = row.get("risk_tags")
        if isinstance(tags, list) and len(tags) > 0:
            return tags  # explode: each tag is its own bucket contribution
        return ["(untagged)"]
    return ["(unknown)"]

# Build per-bucket accumulators (dict-of-lists; means computed at render time, always within bucket)
buckets = collections.defaultdict(lambda: {
    "count": 0,
    "success_count": 0,
    "wall_secs": [],
    "cost": [],
    "budget_breach_count": 0,
    "cap_hit_count": 0,
})

for row in filtered:
    keys = get_bucket_keys(row)
    for key in keys:
        b = buckets[key]
        b["count"] += 1
        exit_code = row.get("exit_code")
        if exit_code == 0:
            b["success_count"] += 1
        ws = row.get("wall_clock_seconds")
        if ws is not None:
            b["wall_secs"].append(float(ws))
        cost = row.get("estimated_cost_usd")
        if cost is not None:
            b["cost"].append(float(cost))
        if row.get("budget_breach") is True:
            b["budget_breach_count"] += 1
        if row.get("cap_hit") is True:
            b["cap_hit_count"] += 1

# ---------------------------------------------------------------------------
# Render markdown — stratified, never global means
# ---------------------------------------------------------------------------
filter_desc_parts = []
if cutoff:
    filter_desc_parts.append(f"since {SINCE_DAYS}")
if FILTER_ROLE:
    filter_desc_parts.append(f"role={FILTER_ROLE}")
filter_desc = ", ".join(filter_desc_parts) if filter_desc_parts else "all time, all roles"

print(f"# Swarm Telemetry Report")
print(f"")
print(f"**Bucket:** `{BUCKET}` | **Filter:** {filter_desc}")
print(f"**Runs matched:** {len(filtered)} of {len(rows)} total")
if excluded_window > 0:
    print(f"**Excluded (outside window):** {excluded_window}")
if excluded_role > 0:
    print(f"**Excluded (other roles):** {excluded_role}")
print(f"")

if not buckets:
    print(f"_No runs matched the current filters._")
    sys.exit(0)

# Sort buckets for stable output
sorted_keys = sorted(buckets.keys())

# Table header
print(f"| {BUCKET} | count | success_rate | mean_wall_s | mean_cost_usd | budget_breach | cap_hit |")
print(f"|{'-'*max(len(BUCKET)+2,10)}|------:|-------------:|------------:|--------------:|--------------:|--------:|")

for key in sorted_keys:
    b = buckets[key]
    count      = b["count"]
    success_rt = b["success_count"] / count if count > 0 else 0.0
    mean_wall  = sum(b["wall_secs"]) / len(b["wall_secs"]) if b["wall_secs"] else None
    mean_cost  = sum(b["cost"]) / len(b["cost"]) if b["cost"] else None
    bb_count   = b["budget_breach_count"]
    cap_count  = b["cap_hit_count"]

    success_str = f"{success_rt:.0%}"
    wall_str    = f"{mean_wall:.1f}" if mean_wall is not None else "n/a"
    cost_str    = f"{mean_cost:.4f}" if mean_cost is not None else "n/a"

    print(f"| `{key}` | {count} | {success_str} | {wall_str} | {cost_str} | {bb_count} | {cap_count} |")

print(f"")
print(f"> _Report generated by swarm-telemetry. Stratified per `{BUCKET}` — do not aggregate across buckets._")
PYEOF
}

# ---------------------------------------------------------------------------
# Subcommand: sample-for-adjudication
# ---------------------------------------------------------------------------
# Picks a stratified random sample of findings from findings.jsonl that do
# not yet have an adjudications.jsonl row. Outputs directory structure
# mirroring ~/.swarm/phase0/runs/<date>/<finding-id-slug>/ so that the
# existing blind-findings + unblind-findings pipeline consumes unchanged.
#
# Anti-pattern guards (enforced):
#   - Stratification mandatory (role × phase_complexity × phase_kind).
#   - Proportional allocation with floor-1 per non-empty stratum.
#   - Rubric version read from highest-versioned swarm-do/rubrics/v*.md.
#   - No hardcoded rubric version.
# ---------------------------------------------------------------------------

_cmd_sample_for_adjudication() {
  local count_target="" since_days="" output_root=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --count)       count_target="${2:-}"; shift 2;;
      --since)       since_days="${2:-}"; shift 2;;
      --output-root) output_root="${2:-}"; shift 2;;
      *) die "sample-for-adjudication: unknown option '$1'";;
    esac
  done

  [[ -n "$count_target" ]] || die "sample-for-adjudication: --count is required"
  if ! [[ "$count_target" =~ ^[0-9]+$ ]]; then
    die "sample-for-adjudication: --count must be a positive integer, got '$count_target'"
  fi

  command -v jq     >/dev/null 2>&1 || die "sample-for-adjudication requires jq"
  command -v python3 >/dev/null 2>&1 || die "sample-for-adjudication requires python3"

  local tel_dir
  tel_dir="$(_resolve_telemetry_dir)"
  local preferred_output_root fallback_output_root
  preferred_output_root="${output_root:-$(_resolve_phase0_root)}"
  fallback_output_root="$(_resolve_phase0_fallback_root)"

  local findings_path="${tel_dir}/findings.jsonl"
  local runs_path="${tel_dir}/runs.jsonl"
  local adjudications_path="${tel_dir}/adjudications.jsonl"

  if [[ ! -f "$findings_path" || ! -s "$findings_path" ]]; then
    die "sample-for-adjudication: findings.jsonl absent or empty at ${findings_path}"
  fi
  if [[ ! -f "$runs_path" || ! -s "$runs_path" ]]; then
    die "sample-for-adjudication: runs.jsonl absent or empty at ${runs_path}"
  fi

  # Parse since_days
  local since_n=""
  if [[ -n "$since_days" ]]; then
    since_n="${since_days%d}"
    if ! [[ "$since_n" =~ ^[0-9]+$ ]]; then
      die "sample-for-adjudication: --since must be Nd (e.g. 30d), got '${since_days}'"
    fi
  fi

  # Find highest-versioned rubric
  local rubric_dir
  rubric_dir="$(dirname "$_SCRIPT_DIR")/rubrics"
  if [[ ! -d "$rubric_dir" ]]; then
    die "sample-for-adjudication: rubrics directory not found at ${rubric_dir}"
  fi

  local highest_rubric
  highest_rubric="$(find "$rubric_dir" -name "v[0-9]*.md" -type f | sort -V | tail -1)"
  if [[ -z "$highest_rubric" ]]; then
    die "sample-for-adjudication: no rubric v*.md found in ${rubric_dir}"
  fi

  # Extract rubric_version from YAML frontmatter
  local rubric_version
  rubric_version="$(grep '^rubric_version:' "$highest_rubric" | head -1 | sed 's/.*"\([^"]*\)".*/\1/')"
  if [[ -z "$rubric_version" ]]; then
    die "sample-for-adjudication: could not parse rubric_version from $(basename "$highest_rubric")"
  fi

  # Use python3 for all heavy lifting
  python3 - \
    "$findings_path" \
    "$runs_path" \
    "$adjudications_path" \
    "$count_target" \
    "$since_n" \
    "$rubric_version" \
    "$preferred_output_root" \
    "$fallback_output_root" \
    <<'PYEOF'
import sys, json, os, random, datetime, re
from collections import defaultdict

findings_path     = sys.argv[1]
runs_path         = sys.argv[2]
adjudications_path = sys.argv[3]
count_target      = int(sys.argv[4])
since_n           = int(sys.argv[5]) if sys.argv[5] else 0
rubric_version    = sys.argv[6]
preferred_output_root = sys.argv[7]
fallback_output_root  = sys.argv[8]

SELF = "swarm-telemetry: sample-for-adjudication"

# ---------------------------------------------------------------------------
# Load runs (for phase_complexity, phase_kind, role metadata)
# ---------------------------------------------------------------------------
runs_by_id = {}
try:
    with open(runs_path) as f:
        for lineno, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
                runs_by_id[obj.get("run_id")] = obj
            except json.JSONDecodeError as e:
                print(f"{SELF}: runs.jsonl line {lineno} parse error: {e} — skipping", file=sys.stderr)
except Exception as e:
    print(f"{SELF}: error reading runs.jsonl: {e}", file=sys.stderr)
    sys.exit(1)

# ---------------------------------------------------------------------------
# Load adjudications (to identify which findings are already adjudicated)
# ---------------------------------------------------------------------------
adjudicated_finding_ids = set()
if os.path.isfile(adjudications_path) and os.path.getsize(adjudications_path) > 0:
    try:
        with open(adjudications_path) as f:
            for lineno, line in enumerate(f, 1):
                line = line.strip()
                if not line:
                    continue
                try:
                    obj = json.loads(line)
                    overridden = obj.get("overridden_finding_ids")
                    if isinstance(overridden, list):
                        for finding_id in overridden:
                            if isinstance(finding_id, str):
                                adjudicated_finding_ids.add(finding_id)
                    direct_finding_id = obj.get("finding_id")
                    if isinstance(direct_finding_id, str):
                        adjudicated_finding_ids.add(direct_finding_id)
                except json.JSONDecodeError:
                    pass
    except Exception as e:
        print(f"{SELF}: error reading adjudications.jsonl: {e}", file=sys.stderr)

def parse_ts(s):
    if not s:
        return None
    try:
        return datetime.datetime.fromisoformat(s.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None

# ---------------------------------------------------------------------------
# Parse cutoff timestamp
# ---------------------------------------------------------------------------
def resolve_now():
    override = os.environ.get("SWARM_TELEMETRY_NOW", "").strip()
    if not override:
        return datetime.datetime.now(datetime.timezone.utc)
    parsed = parse_ts(override)
    if parsed is None:
        print(f"{SELF}: invalid SWARM_TELEMETRY_NOW '{override}'", file=sys.stderr)
        sys.exit(1)
    return parsed

now = resolve_now()
cutoff = None
if since_n > 0:
    cutoff = now - datetime.timedelta(days=since_n)

# ---------------------------------------------------------------------------
# Load findings and stratify
# ---------------------------------------------------------------------------
strata = defaultdict(list)  # (role, phase_complexity, phase_kind) -> [findings]

try:
    with open(findings_path) as f:
        for lineno, line in enumerate(f, 1):
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)

                # Filter by since_days if specified
                if cutoff:
                    ts = parse_ts(obj.get("timestamp"))
                    if ts and ts < cutoff:
                        continue

                finding_id = obj.get("finding_id")
                if isinstance(finding_id, str) and finding_id in adjudicated_finding_ids:
                    continue

                # Enrich with run metadata
                run_id = obj.get("run_id")
                run = runs_by_id.get(run_id, {})

                role = run.get("role", "unknown")
                phase_complexity = run.get("phase_complexity", "unknown")
                phase_kind = run.get("phase_kind", "unknown")

                stratum_key = (role, phase_complexity, phase_kind)
                strata[stratum_key].append(obj)
            except json.JSONDecodeError as e:
                print(f"{SELF}: findings.jsonl line {lineno} parse error: {e} — skipping", file=sys.stderr)
except Exception as e:
    print(f"{SELF}: error reading findings.jsonl: {e}", file=sys.stderr)
    sys.exit(1)

if not strata:
    print(f"{SELF}: no findings matched filter criteria", file=sys.stderr)
    sys.exit(1)

# ---------------------------------------------------------------------------
# Proportional allocation with floor-1 per non-empty stratum
# ---------------------------------------------------------------------------
stratum_counts = {k: len(v) for k, v in strata.items()}
total_findings = sum(stratum_counts.values())

# Allocate proportionally with floor-1
allocation = {}
allocated_total = 0
for stratum_key in strata.keys():
    proportion = stratum_counts[stratum_key] / total_findings
    base_alloc = int(proportion * count_target)
    # Floor-1 guarantee: at least 1 per non-empty stratum if we have budget
    alloc = max(1, base_alloc)
    allocation[stratum_key] = alloc
    allocated_total += alloc

# If we overallocated due to floor-1, trim the largest strata
if allocated_total > count_target:
    overage = allocated_total - count_target
    # Sort strata by allocation (descending)
    sorted_strata = sorted(allocation.items(), key=lambda x: -x[1])
    for stratum_key, _ in sorted_strata:
        if overage <= 0:
            break
        trim = min(overage, allocation[stratum_key] - 1)
        allocation[stratum_key] -= trim
        overage -= trim

# ---------------------------------------------------------------------------
# Sample findings from each stratum and output
# ---------------------------------------------------------------------------
batch_id = now.strftime("%Y%m%d%H%M%S")
date_dir = now.strftime("%Y-%m-%d")
preferred_base_output_dir = os.path.abspath(os.path.expanduser(preferred_output_root))
fallback_base_output_dir = os.path.abspath(os.path.expanduser(fallback_output_root))
output_root = os.path.join(preferred_base_output_dir, date_dir)

try:
    os.makedirs(output_root, exist_ok=True)
except PermissionError:
    fallback_output = os.path.join(fallback_base_output_dir, date_dir)
    if os.path.abspath(fallback_output) == os.path.abspath(output_root):
        raise
    print(
        f"{SELF}: preferred output root '{preferred_base_output_dir}' is not writable; falling back to '{fallback_base_output_dir}'",
        file=sys.stderr,
    )
    os.makedirs(fallback_output, exist_ok=True)
    output_root = fallback_output

sampled = []
for stratum_key, target_count in allocation.items():
    findings_in_stratum = strata[stratum_key]
    sample_count = min(target_count, len(findings_in_stratum))
    sampled_findings = random.sample(findings_in_stratum, sample_count)

    for finding in sampled_findings:
        sampled.append((stratum_key, finding))

random.shuffle(sampled)

# Output each sampled finding to its own subdir
for stratum_key, finding in sampled:
    role = stratum_key[0]
    finding_id = finding.get("finding_id", "unknown")

    # Create slug from finding_id
    finding_slug = finding_id.lower()[:12]  # Use first 12 chars of ULID

    phase_dir = os.path.join(output_root, finding_slug)
    os.makedirs(phase_dir, exist_ok=True)

    # Determine role-specific subdir (claude/findings.json or codex-mode-a/findings.json)
    role_subdir_map = {
        "agent-review": "claude",
        "agent-writer": "claude",
        "agent-research": "claude",
        "agent-clarify": "claude",
        "agent-analysis": "claude",
        "agent-spec-review": "claude",
        "agent-code-review": "claude",
        "agent-codex-review": "codex-mode-a",
        "agent-code-synthesizer": "codex-mode-a",
        "agent-docs": "codex-mode-a",
        "agent-debug": "codex-mode-a",
    }
    role_subdir = role_subdir_map.get(role, "claude")

    findings_subdir = os.path.join(phase_dir, role_subdir)
    os.makedirs(findings_subdir, exist_ok=True)

    # Write findings.json (as an array with one element)
    findings_json_path = os.path.join(findings_subdir, "findings.json")
    with open(findings_json_path, "w") as f:
        json.dump([finding], f, indent=2)

print(f"{SELF}: sampled {len(sampled)} findings into {output_root}")
print(f"{SELF}: rubric version: {rubric_version}")
print(f"{SELF}: batch_id: {batch_id}")
PYEOF
}

# ---------------------------------------------------------------------------
# Subcommand: join-outcomes
# ---------------------------------------------------------------------------
# Correlates findings.jsonl entries with post-merge git commits and bd/gh
# references to determine maintainer_action and append rows to
# finding_outcomes.jsonl.
#
# Anti-pattern guards (enforced):
#   - No cron; manual invocation only.
#   - Line range MUST participate in hotfix correlation; file-only match forbidden.
#   - Never mutates outcomes.jsonl or outcomes.schema.json.
#   - Append-only: never rewrites existing finding_outcomes.jsonl rows.
# ---------------------------------------------------------------------------

_cmd_join_outcomes() {
  local since_days="30d" repo_path="" dry_run=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --since)   since_days="${2:-}"; shift 2;;
      --repo)    repo_path="${2:-}";  shift 2;;
      --dry-run) dry_run=1; shift;;
      *) die "join-outcomes: unknown option '$1'";;
    esac
  done

  command -v jq     >/dev/null 2>&1 || die "join-outcomes requires jq"
  command -v git    >/dev/null 2>&1 || die "join-outcomes requires git"
  command -v python3 >/dev/null 2>&1 || die "join-outcomes requires python3"

  # Resolve repo root
  if [[ -z "$repo_path" ]]; then
    repo_path="$(git rev-parse --show-toplevel 2>/dev/null)" \
      || die "join-outcomes: --repo not provided and not inside a git repo"
  fi
  [[ -d "$repo_path/.git" || -f "$repo_path/.git" ]] \
    || die "join-outcomes: '$repo_path' is not a git repository root"

  local tel_dir
  tel_dir="$(_resolve_telemetry_dir)"

  local findings_path="${tel_dir}/findings.jsonl"
  local ledger_path="${tel_dir}/finding_outcomes.jsonl"

  if [[ ! -f "$findings_path" || ! -s "$findings_path" ]]; then
    echo "${_SELF}: join-outcomes: findings.jsonl absent or empty — nothing to correlate" >&2
    return 0
  fi

  # Parse since_days to a cutoff epoch (seconds since 1970-01-01)
  local since_n
  since_n="${since_days%d}"
  if ! [[ "$since_n" =~ ^[0-9]+$ ]]; then
    die "join-outcomes: --since must be Nd (e.g. 30d), got '${since_days}'"
  fi

  # Use python3 for all heavy correlation — keeps bash handling minimal
  python3 - \
    "$findings_path" \
    "$ledger_path" \
    "$repo_path" \
    "$since_n" \
    "$dry_run" \
    <<'PYEOF'
import sys, json, os, subprocess, datetime, re, hashlib, secrets

findings_path = sys.argv[1]
ledger_path   = sys.argv[2]
repo_path     = sys.argv[3]
since_n       = int(sys.argv[4])
dry_run       = sys.argv[5] == "1"

SELF = "swarm-telemetry: join-outcomes"

# ---------------------------------------------------------------------------
# ULID generator (Crockford base32, 26 chars) — no external deps
# ---------------------------------------------------------------------------
CROCKFORD = "0123456789ABCDEFGHJKMNPQRSTVWXYZ"

def _ulid() -> str:
    now_ms = int(datetime.datetime.now(datetime.timezone.utc).timestamp() * 1000)
    # 48-bit time (10 chars) + 80-bit random (16 chars)
    ts_bits = now_ms
    t_chars = []
    for _ in range(10):
        t_chars.append(CROCKFORD[ts_bits & 0x1F])
        ts_bits >>= 5
    t_part = "".join(reversed(t_chars))
    rand_bytes = secrets.token_bytes(10)
    rand_int = int.from_bytes(rand_bytes, "big")
    r_chars = []
    for _ in range(16):
        r_chars.append(CROCKFORD[rand_int & 0x1F])
        rand_int >>= 5
    r_part = "".join(reversed(r_chars))
    return t_part + r_part

# ---------------------------------------------------------------------------
# Now / cutoff
# ---------------------------------------------------------------------------
now = datetime.datetime.now(datetime.timezone.utc)
cutoff = now - datetime.timedelta(days=since_n)
observed_at = now.strftime("%Y-%m-%dT%H:%M:%SZ")

def parse_ts(s):
    if not s:
        return None
    try:
        return datetime.datetime.fromisoformat(s.replace("Z", "+00:00"))
    except (ValueError, AttributeError):
        return None

# ---------------------------------------------------------------------------
# Load existing finding_outcomes for dedup
# ---------------------------------------------------------------------------
existing_keys = set()  # (finding_id, maintainer_action, followup_ref)
if os.path.isfile(ledger_path) and os.path.getsize(ledger_path) > 0:
    with open(ledger_path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
                key = (
                    obj.get("finding_id", ""),
                    obj.get("maintainer_action", ""),
                    obj.get("followup_ref") or "",  # normalize None -> ""
                )
                existing_keys.add(key)
            except json.JSONDecodeError:
                pass  # corrupt row; skip but don't block

def is_dup(finding_id, maintainer_action, followup_ref):
    key = (finding_id, maintainer_action, followup_ref or "")
    return key in existing_keys

def mark_seen(finding_id, maintainer_action, followup_ref):
    existing_keys.add((finding_id, maintainer_action, followup_ref or ""))

# ---------------------------------------------------------------------------
# Load findings
# ---------------------------------------------------------------------------
findings = []
with open(findings_path) as f:
    for lineno, line in enumerate(f, 1):
        line = line.strip()
        if not line:
            continue
        try:
            obj = json.loads(line)
            findings.append(obj)
        except json.JSONDecodeError as e:
            print(f"{SELF}: findings.jsonl line {lineno} parse error: {e} — skipping", file=sys.stderr)

if not findings:
    print(f"{SELF}: no findings loaded — nothing to correlate", file=sys.stderr)
    sys.exit(0)

# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------
def git(*args, cwd=repo_path, check=False):
    """Run a git command; return stdout string or "" on error."""
    try:
        result = subprocess.run(
            ["git"] + list(args),
            cwd=cwd,
            capture_output=True,
            text=True,
            timeout=30,
        )
        if check and result.returncode != 0:
            return ""
        return result.stdout.strip()
    except Exception as e:
        print(f"{SELF}: git {' '.join(args)}: {e}", file=sys.stderr)
        return ""

def epoch_of_commit(sha):
    out = git("log", "-1", "--format=%ct", sha)
    try:
        return int(out)
    except (ValueError, TypeError):
        return None

def commit_message(sha):
    return git("log", "-1", "--format=%s", sha)

# ---------------------------------------------------------------------------
# Discover merged commits in the since window via git log --merges
# ---------------------------------------------------------------------------
# We look back since_n days for merge commits; the 14d hotfix window is
# applied per-finding relative to merge timestamp.
since_epoch = int(cutoff.timestamp())

merge_log = git(
    "log", "--merges",
    f"--after={since_epoch}",
    "--format=%H %ct",
    "--no-walk=unsorted",
)
# Also get regular (non-merge) commits if gh cli isn't available
all_commit_log = git(
    "log",
    f"--after={since_epoch}",
    "--format=%H %ct",
)

# Build list of (sha, commit_epoch) for all commits in window
all_commits = []
for line in all_commit_log.splitlines():
    parts = line.split()
    if len(parts) == 2:
        sha, ct = parts
        try:
            all_commits.append((sha, int(ct)))
        except ValueError:
            pass

# Attempt gh pr list for richer PR merge timestamps
# gh pr list --state merged returns merged PRs; use merge timestamp from there
gh_merges = {}  # sha -> merge_epoch
gh_available = False
try:
    gh_result = subprocess.run(
        ["gh", "pr", "list", "--state", "merged", "--limit", "200",
         "--json", "mergeCommit,mergedAt,number,url"],
        cwd=repo_path,
        capture_output=True,
        text=True,
        timeout=30,
    )
    if gh_result.returncode == 0:
        gh_available = True
        prs = json.loads(gh_result.stdout or "[]")
        for pr in prs:
            mc = pr.get("mergeCommit") or {}
            sha = mc.get("oid", "")
            merged_at = pr.get("mergedAt", "")
            if sha and merged_at:
                ts = parse_ts(merged_at)
                if ts:
                    gh_merges[sha] = int(ts.timestamp())
except Exception as e:
    print(f"{SELF}: gh pr list failed (non-fatal): {e}", file=sys.stderr)

merge_candidates = {}
for line in merge_log.splitlines():
    parts = line.split()
    if len(parts) != 2:
        continue
    sha, ct = parts
    try:
        merge_candidates[sha] = int(ct)
    except ValueError:
        continue

for sha, merge_epoch in gh_merges.items():
    merge_candidates[sha] = merge_epoch

sorted_merge_candidates = sorted(merge_candidates.items(), key=lambda item: item[1])

# ---------------------------------------------------------------------------
# Parse git diff --unified=0 hunk headers to extract touched line ranges
# ---------------------------------------------------------------------------
HUNK_RE = re.compile(r"^@@ -(\d+)(?:,(\d+))? \+(\d+)(?:,(\d+))? @@")

def hunk_ranges_for_commit(sha, file_path):
    """Return list of (new_start, new_end) inclusive line ranges touched by sha in file_path."""
    diff_out = git("diff", "--unified=0", f"{sha}^..{sha}", "--", file_path)
    ranges = []
    for line in diff_out.splitlines():
        m = HUNK_RE.match(line)
        if m:
            new_start = int(m.group(3))
            new_count_s = m.group(4)
            new_count = int(new_count_s) if new_count_s is not None else 1
            if new_count == 0:
                # deletion-only hunk; use old range (+0,0 means insertion at new_start)
                old_start = int(m.group(1))
                old_count_s = m.group(2)
                old_count = int(old_count_s) if old_count_s is not None else 1
                ranges.append((old_start, old_start + old_count - 1))
            else:
                ranges.append((new_start, new_start + new_count - 1))
    return ranges

def overlaps(hunk_start, hunk_end, find_start, find_end, window=10):
    """True if [hunk_start,hunk_end] overlaps [find_start-window, find_end+window]."""
    lo = find_start - window
    hi = find_end + window
    return hunk_start <= hi and hunk_end >= lo

def merge_anchor_for_finding(file_path, find_start, find_end, find_epoch):
    """Pick the nearest merge commit touching the finding's file+line window."""
    candidates = []
    max_anchor_delta = 14 * 86400

    for sha, merge_epoch in sorted_merge_candidates:
        if merge_epoch is None:
            continue
        if abs(merge_epoch - find_epoch) > max_anchor_delta:
            continue
        ranges = hunk_ranges_for_commit(sha, file_path)
        if any(overlaps(h_start, h_end, find_start, find_end) for h_start, h_end in ranges):
            candidates.append((sha, merge_epoch))

    if not candidates:
        return None

    after = [candidate for candidate in candidates if candidate[1] >= find_epoch]
    if after:
        return min(after, key=lambda candidate: (candidate[1] - find_epoch, candidate[1]))

    before = [candidate for candidate in candidates if candidate[1] < find_epoch]
    if before:
        return min(before, key=lambda candidate: (find_epoch - candidate[1], -candidate[1]))

    return None

# ---------------------------------------------------------------------------
# bd follow-up detection: bd list --notes <finding_id>
# ---------------------------------------------------------------------------
bd_available = False
try:
    bd_chk = subprocess.run(["bd", "--version"], capture_output=True, text=True, timeout=10)
    bd_available = bd_chk.returncode == 0
except Exception:
    pass

def bd_find_followup(finding_id):
    """Return list of bd issue ids whose notes contain finding_id substring."""
    if not bd_available:
        return []
    try:
        result = subprocess.run(
            ["bd", "list", "--notes", finding_id],
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode != 0:
            return []
        refs = []
        for line in result.stdout.splitlines():
            line = line.strip()
            if line and finding_id in line:
                # Extract the issue id (first whitespace-delimited token)
                parts = line.split()
                if parts:
                    refs.append(parts[0])
        return refs
    except Exception:
        return []

# ---------------------------------------------------------------------------
# gh pr follow-up detection: gh pr list --search <finding_id> --state all
# ---------------------------------------------------------------------------
def gh_find_followup_prs(finding_id):
    """Return list of PR number strings whose body/title contains finding_id."""
    if not gh_available:
        return []
    try:
        result = subprocess.run(
            ["gh", "pr", "list", "--search", finding_id, "--state", "all",
             "--limit", "50", "--json", "number,url"],
            cwd=repo_path,
            capture_output=True, text=True, timeout=15,
        )
        if result.returncode != 0:
            return []
        prs = json.loads(result.stdout or "[]")
        return [str(pr["number"]) for pr in prs if "number" in pr]
    except Exception:
        return []

# ---------------------------------------------------------------------------
# Accumulate rows to write
# ---------------------------------------------------------------------------
new_rows = []

for finding in findings:
    finding_id  = finding.get("finding_id", "")
    file_path   = finding.get("file_path") or ""
    line_start  = finding.get("line_start")
    line_end    = finding.get("line_end")
    find_ts_str = finding.get("timestamp", "")
    find_ts     = parse_ts(find_ts_str)

    if not finding_id:
        continue

    # Skip findings outside the since window
    if find_ts and find_ts < cutoff:
        continue

    # ------------------------------------------------------------------
    # 1. bd follow-up detection
    # ------------------------------------------------------------------
    bd_refs = bd_find_followup(finding_id)
    for bd_ref in bd_refs:
        action = "followup_issue"
        if not is_dup(finding_id, action, bd_ref):
            row = {
                "finding_outcome_id": _ulid(),
                "finding_id": finding_id,
                "observed_at": observed_at,
                "maintainer_action": action,
                "followup_ref": bd_ref,
                "time_to_action_hours": None,
                "time_to_fix_hours": None,
                "recurrence_of": None,
                "schema_ok": True,
            }
            new_rows.append(row)
            mark_seen(finding_id, action, bd_ref)

    # ------------------------------------------------------------------
    # 2. gh PR follow-up detection
    # ------------------------------------------------------------------
    gh_pr_refs = gh_find_followup_prs(finding_id)
    for pr_num in gh_pr_refs:
        action = "followup_pr"
        if not is_dup(finding_id, action, pr_num):
            row = {
                "finding_outcome_id": _ulid(),
                "finding_id": finding_id,
                "observed_at": observed_at,
                "maintainer_action": action,
                "followup_ref": pr_num,
                "time_to_action_hours": None,
                "time_to_fix_hours": None,
                "recurrence_of": None,
                "schema_ok": True,
            }
            new_rows.append(row)
            mark_seen(finding_id, action, pr_num)

    # ------------------------------------------------------------------
    # 3. Hotfix correlation — requires file_path AND line_start
    #    (line-only match is forbidden; must verify line range overlap)
    # ------------------------------------------------------------------
    if not file_path or line_start is None:
        # Cannot do line-range correlation; skip hotfix check
        # Only emit 'ignored' if no bd/gh refs were found AND
        # the finding has no file_path at all (unlocatable).
        if not bd_refs and not gh_pr_refs and not file_path:
            action = "ignored"
            if not is_dup(finding_id, action, ""):
                row = {
                    "finding_outcome_id": _ulid(),
                    "finding_id": finding_id,
                    "observed_at": observed_at,
                    "maintainer_action": action,
                    "followup_ref": None,
                    "time_to_action_hours": None,
                    "time_to_fix_hours": None,
                    "recurrence_of": None,
                    "schema_ok": True,
                }
                new_rows.append(row)
                mark_seen(finding_id, action, "")
        continue

    # Normalize line_end
    ls = int(line_start)
    le = int(line_end) if line_end is not None else ls

    # Anchor hotfix detection to the nearest actual merge commit touching the
    # same file + line window. Do not use the finding timestamp as the 14d anchor.
    find_epoch = int(find_ts.timestamp()) if find_ts else int(now.timestamp())
    merge_anchor = merge_anchor_for_finding(file_path, ls, le, find_epoch)
    if merge_anchor is None:
        continue
    merge_sha, merge_epoch = merge_anchor

    # Enumerate commits that touch file_path within 14d after merge_epoch
    hotfix_commits_raw = git(
        "log",
        f"--after={merge_epoch}",
        f"--before={merge_epoch + 14 * 86400}",
        "--format=%H %ct",
        "--",
        file_path,
    )

    for cline in hotfix_commits_raw.splitlines():
        parts = cline.split()
        if len(parts) < 2:
            continue
        sha, commit_ct_s = parts[0], parts[1]
        try:
            commit_ct = int(commit_ct_s)
        except ValueError:
            continue

        if sha == merge_sha or commit_ct <= merge_epoch:
            continue

        # Parse diff hunk ranges — line range MUST participate
        ranges = hunk_ranges_for_commit(sha, file_path)
        if not ranges:
            continue  # no changes in this file for this commit

        hit = any(overlaps(h_start, h_end, ls, le) for h_start, h_end in ranges)
        if not hit:
            continue  # file touched but not in ±10 line window

        # Record hotfix_within_14d
        action = "hotfix_within_14d"
        followup_ref = sha
        if not is_dup(finding_id, action, followup_ref):
            time_to_fix = (commit_ct - merge_epoch) / 3600.0
            row = {
                "finding_outcome_id": _ulid(),
                "finding_id": finding_id,
                "observed_at": observed_at,
                "maintainer_action": action,
                "followup_ref": followup_ref,
                "time_to_action_hours": None,
                "time_to_fix_hours": round(time_to_fix, 4) if time_to_fix is not None else None,
                "recurrence_of": None,
                "schema_ok": True,
            }
            new_rows.append(row)
            mark_seen(finding_id, action, followup_ref)

# ---------------------------------------------------------------------------
# Output / append
# ---------------------------------------------------------------------------
if not new_rows:
    print(f"{SELF}: no new outcome rows to append", file=sys.stderr)
    sys.exit(0)

if dry_run:
    print(f"{SELF}: --dry-run: {len(new_rows)} row(s) would be appended (not written)", file=sys.stderr)
    for row in new_rows:
        print(json.dumps(row))
    sys.exit(0)

# Ensure telemetry directory exists
os.makedirs(os.path.dirname(ledger_path), exist_ok=True)

appended = 0
with open(ledger_path, "a") as f:
    for row in new_rows:
        f.write(json.dumps(row, separators=(",", ":")) + "\n")
        appended += 1

print(f"{SELF}: appended {appended} row(s) to {ledger_path}", file=sys.stderr)
PYEOF
}

# ---------------------------------------------------------------------------
# Self-test
# ---------------------------------------------------------------------------

_cmd_test() {
  local _pass=0 _fail=0 _skip=0

  _check() {
    local desc="$1" got="$2" want="$3"
    if [[ "$got" == "$want" ]]; then
      echo "  PASS: $desc"
      (( _pass++ )) || true
    else
      echo "  FAIL: $desc — got '${got}', want '${want}'"
      (( _fail++ )) || true
    fi
  }

  _check_contains() {
    local desc="$1" haystack="$2" needle="$3"
    if [[ "$haystack" == *"$needle"* ]]; then
      echo "  PASS: $desc"
      (( _pass++ )) || true
    else
      echo "  FAIL: $desc — output does not contain '${needle}'"
      (( _fail++ )) || true
    fi
  }

  _check_not_contains() {
    local desc="$1" haystack="$2" needle="$3"
    if [[ "$haystack" != *"$needle"* ]]; then
      echo "  PASS: $desc"
      (( _pass++ )) || true
    else
      echo "  FAIL: $desc — output must NOT contain '${needle}'"
      (( _fail++ )) || true
    fi
  }

  echo "=== swarm-telemetry --test ==="
  echo ""

  # Locate synthetic fixture
  local fixture_dir="${_SCRIPT_DIR}/../tests/fixtures"
  local syn_runs="${fixture_dir}/synthetic-runs.jsonl"
  local syn_findings="${fixture_dir}/synthetic-findings.jsonl"

  if [[ ! -f "$syn_runs" ]]; then
    echo "  SKIP: synthetic fixtures not found at ${syn_runs}" >&2
    (( _skip++ )) || true
    echo ""
    echo "=== self-test: ${_pass} passed, ${_fail} failed, ${_skip} skipped ==="
    [[ "$_fail" -eq 0 ]] && exit 0 || exit 1
  fi

  # Use a temp dir as CLAUDE_PLUGIN_DATA for isolation
  local tmp_tel
  tmp_tel="$(mktemp -d /tmp/swarm-telemetry-test-XXXXXX)"
  local tmp_data="${tmp_tel}/fake-plugin-data"
  local test_now="2026-04-23T12:00:00Z"
  mkdir -p "${tmp_data}/telemetry"
  cp "$syn_runs"    "${tmp_data}/telemetry/runs.jsonl"
  cp "$syn_findings" "${tmp_data}/telemetry/findings.jsonl"
  # Leave outcomes/adjudications absent to test fail-open

  echo "--- dump subcommand ---"
  local dump_out
  dump_out="$(CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" dump runs 2>/dev/null)"
  _check "dump runs: starts with '['" "${dump_out:0:1}" "["
  local run_count
  run_count="$(printf '%s' "$dump_out" | jq 'length' 2>/dev/null || echo "0")"
  _check "dump runs: ≥60 rows" "$(( run_count >= 60 ))" "1"

  local dump_findings_out
  dump_findings_out="$(CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" dump findings 2>/dev/null)"
  local findings_count
  findings_count="$(printf '%s' "$dump_findings_out" | jq 'length' 2>/dev/null || echo "0")"
  _check "dump findings: ≥30 rows" "$(( findings_count >= 30 ))" "1"

  local dump_absent_out
  dump_absent_out="$(CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" dump outcomes 2>/dev/null)"
  _check "dump absent ledger returns []" "$dump_absent_out" "[]"

  echo ""
  echo "--- validate subcommand ---"
  local val_rc=0
  CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" validate 2>/dev/null || val_rc=$?
  _check "validate: exits 0 on clean synthetic data" "$val_rc" "0"

  # Corrupt a copy — truncate mid-JSON
  local corrupt_dir="${tmp_data}/telemetry-corrupt"
  mkdir -p "$corrupt_dir"
  # Write 3 good rows then one truncated row
  head -3 "${tmp_data}/telemetry/runs.jsonl" > "${corrupt_dir}/runs.jsonl"
  printf '{"run_id":"CORRUPT","timestamp_start":"2026-01-01T' >> "${corrupt_dir}/runs.jsonl"
  local corrupt_data="${tmp_data%/*}/corrupt-plugin-data"
  mkdir -p "${corrupt_data}/telemetry"
  cp "${corrupt_dir}/runs.jsonl" "${corrupt_data}/telemetry/runs.jsonl"

  local val_corrupt_rc=0
  CLAUDE_PLUGIN_DATA="$corrupt_data" bash "$0" validate runs 2>/dev/null || val_corrupt_rc=$?
  _check "validate: exits 1 on truncated/corrupt row" "$(( val_corrupt_rc != 0 ))" "1"

  local type_bad_data="${tmp_data%/*}/type-bad-plugin-data"
  mkdir -p "${type_bad_data}/telemetry"
  cat > "${type_bad_data}/telemetry/runs.jsonl" <<'EOF'
{"run_id":"R1","timestamp_start":"2026-01-01T00:00:00Z","timestamp_end":"2026-01-01T00:01:00Z","backend":"codex","model":"gpt-5.4","effort":"medium","prompt_bundle_hash":null,"config_hash":null,"role":"agent-review","phase_kind":null,"phase_complexity":null,"risk_tags":null,"issue_id":"mstefanko-plugins-001","repo":null,"base_sha":null,"head_sha":null,"diff_size_bytes":null,"input_tokens":null,"cached_input_tokens":null,"output_tokens":null,"estimated_cost_usd":null,"wall_clock_seconds":"not-a-number","tool_call_count":null,"cap_hit":null,"budget_breach":null,"schema_ok":true,"exit_code":0,"setting_source":null,"writer_status":null,"review_verdict":null,"last_429_at":null}
EOF
  local val_type_rc=0
  CLAUDE_PLUGIN_DATA="$type_bad_data" bash "$0" validate runs 2>/dev/null || val_type_rc=$?
  _check "validate: exits 1 on wrong field type" "$(( val_type_rc != 0 ))" "1"

  echo ""
  echo "--- report subcommand ---"
  local report_out
  report_out="$(SWARM_TELEMETRY_NOW="$test_now" CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" report 2>/dev/null)"
  _check_contains "report: contains markdown header" "$report_out" "# Swarm Telemetry Report"
  _check_contains "report: contains bucket header" "$report_out" "role"
  _check_not_contains "report: no global mean aggregation" "$report_out" "global"

  local report_since_out
  report_since_out="$(SWARM_TELEMETRY_NOW="$test_now" CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" report --since 30d --role agent-review 2>/dev/null)"
  _check_contains "report --since 30d --role agent-review: shows filter" "$report_since_out" "since 30d"
  _check_contains "report --since 30d --role agent-review: shows role filter" "$report_since_out" "role=agent-review"
  _check_not_contains "report --since 30d --role agent-review: excludes other roles in bucket col" "$report_since_out" "agent-writer"

  local report_risk_out
  report_risk_out="$(SWARM_TELEMETRY_NOW="$test_now" CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" report --bucket risk_tag 2>/dev/null)"
  _check_contains "report --bucket risk_tag: has (untagged)" "$report_risk_out" "(untagged)"
  _check_contains "report --bucket risk_tag: has markdown table" "$report_risk_out" "| risk_tag |"

  local report_complexity_out
  report_complexity_out="$(SWARM_TELEMETRY_NOW="$test_now" CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" report --bucket complexity 2>/dev/null)"
  _check_contains "report --bucket complexity: has (none)" "$report_complexity_out" "(none)"

  echo ""
  echo "--- query subcommand ---"
  if command -v python3 >/dev/null 2>&1; then
    local query_out
    query_out="$(CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" query 'SELECT role, count(*) as n FROM runs GROUP BY role ORDER BY n DESC' 2>/dev/null)"
    _check_contains "query: returns role column" "$query_out" "role"
    _check_contains "query: returns count results" "$query_out" "agent-analysis"
  else
    echo "  SKIP: python3 not available"
    (( _skip++ )) || true
  fi

  echo ""
  echo "--- sample-for-adjudication subcommand ---"
  if command -v python3 >/dev/null 2>&1; then
    local read_only_phase0="${tmp_tel}/read-only-phase0"
    mkdir -p "$read_only_phase0"
    chmod 500 "$read_only_phase0"

    local sample_rc=0
    SWARM_PHASE0_ROOT="${read_only_phase0}/runs" SWARM_TELEMETRY_NOW="$test_now" CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" sample-for-adjudication --count 5 2>/dev/null || sample_rc=$?
    _check "sample-for-adjudication: exits 0 with valid input" "$sample_rc" "0"
    _check "sample-for-adjudication: falls back to plugin-data output root" "$([ -d "${tmp_data}/phase0/runs/2026-04-23" ] && echo 1 || echo 0)" "1"

    rm -rf "${tmp_data}/phase0"

    local remaining_finding_id
    remaining_finding_id="$(head -n 1 "$syn_findings" | jq -r '.finding_id' 2>/dev/null || true)"
    python3 - "$syn_findings" "$remaining_finding_id" "${tmp_data}/telemetry/adjudications.jsonl" <<'PYEOF'
import json
import sys

findings_path = sys.argv[1]
remaining_id = sys.argv[2]
out_path = sys.argv[3]

with open(findings_path, "r", encoding="utf-8") as f:
    finding_ids = [json.loads(line)["finding_id"] for line in f if line.strip()]

excluded_ids = [finding_id for finding_id in finding_ids if finding_id != remaining_id]
row = {
    "adjudication_id": "01ARZ3NDEKTSV4RRFFQ69G5FAA",
    "outcome_id": "01ARZ3NDEKTSV4RRFFQ69G5FAB",
    "issue_id": "mstefanko-plugins-001",
    "timestamp": "2026-04-23T12:00:00Z",
    "adjudicator": "human",
    "decision": "SPLIT",
    "schema_ok": True,
    "overridden_finding_ids": excluded_ids,
}

with open(out_path, "w", encoding="utf-8") as f:
    f.write(json.dumps(row) + "\n")
PYEOF

    local sample_exclusion_rc=0
    SWARM_PHASE0_ROOT="${read_only_phase0}/runs" SWARM_TELEMETRY_NOW="$test_now" CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" sample-for-adjudication --count 1 2>/dev/null || sample_exclusion_rc=$?
    _check "sample-for-adjudication: exits 0 with adjudicated findings excluded" "$sample_exclusion_rc" "0"

    local sampled_findings_json
    sampled_findings_json="$(find "${tmp_data}/phase0/runs/2026-04-23" -name findings.json | head -1)"
    local sampled_finding_id=""
    if [[ -n "$sampled_findings_json" ]]; then
      sampled_finding_id="$(jq -r '.[0].finding_id' "$sampled_findings_json" 2>/dev/null || true)"
    fi
    _check "sample-for-adjudication: skips already adjudicated findings" "$sampled_finding_id" "$remaining_finding_id"

    local sample_missing_count_rc=1
    CLAUDE_PLUGIN_DATA="$tmp_data" bash "$0" sample-for-adjudication 2>/dev/null || sample_missing_count_rc=$?
    _check "sample-for-adjudication: exits 1 when --count missing" "$(( sample_missing_count_rc != 0 ))" "1"
  else
    echo "  SKIP: python3 not available"
    (( _skip++ )) || true
  fi

  # Cleanup
  rm -rf "$tmp_tel" "${corrupt_data}" 2>/dev/null || true

  echo ""
  echo "=== self-test: ${_pass} passed, ${_fail} failed, ${_skip} skipped ==="
  [[ "$_fail" -eq 0 ]] && exit 0 || exit 1
}

# ---------------------------------------------------------------------------
# Argument dispatcher
# ---------------------------------------------------------------------------

[[ $# -gt 0 ]] || { usage; exit 64; }

case "$1" in
  -h|--help) usage; exit 0;;
  --test)    _cmd_test;;
  query)
    shift
    _cmd_query "${1:-}"
    ;;
  report)
    shift
    _cmd_report "$@"
    ;;
  dump)
    shift
    _cmd_dump "${1:-}"
    ;;
  validate)
    shift
    _cmd_validate "${1:-}"
    ;;
  sample-for-adjudication)
    shift
    _cmd_sample_for_adjudication "$@"
    ;;
  join-outcomes)
    shift
    _cmd_join_outcomes "$@"
    ;;
  *)
    echo "${_SELF}: unknown subcommand '$1'" >&2
    usage >&2
    exit 64
    ;;
esac
