#!/usr/bin/env bash
# swarm-run — M1 manual fallback runner for the beads-centric swarm.
# Usage: swarm-run --backend {claude|codex} --issue <id> [--role <role>] [--mode {normal|fallback|competition}] [--dry-run]
# Scope: only these roles — agent-writer, agent-spec-review, agent-review, agent-codex-review.
# See the swarm-do plugin README for operator docs.

set -euo pipefail

# shellcheck source=_lib/paths.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib/paths.sh"
# shellcheck source=_lib/beads-preflight.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib/beads-preflight.sh"

BACKEND=""; ISSUE=""; ROLE=""; MODE="normal"; DRY_RUN=0

usage() {
  cat <<'EOF'
swarm-run — run a single swarm role against a beads issue on the selected backend.

Usage:
  swarm-run --backend {claude|codex} --issue <id> [--role <role>] [--mode {normal|fallback|competition}] [--dry-run]

Flags:
  --backend    claude|codex (required)
  --issue      beads issue id, e.g. bd-123 (required)
  --role       one of: agent-writer, agent-spec-review, agent-review, agent-codex-review
               if omitted, inferred from the issue's assignee
  --mode       normal (default) | fallback | competition
  --dry-run    print what would happen, do not invoke backend or mutate beads
  -h, --help   show this help

Env:
  SWARM_EFFORT_OVERRIDE=xhigh   escalate codex effort (codex backend only)
  SWARM_CODEX_REVIEW_TIMEOUT_SECONDS=60
                                discard agent-codex-review after this many seconds

Examples:
  swarm-run --backend codex --issue bd-42
  swarm-run --backend codex --issue bd-42 --mode fallback
  swarm-run --backend codex --issue bd-42 --role agent-codex-review
  swarm-run --backend claude --issue bd-42 --dry-run
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --backend) BACKEND="${2:-}"; shift 2;;
    --issue)   ISSUE="${2:-}";   shift 2;;
    --role)    ROLE="${2:-}";    shift 2;;
    --mode)    MODE="${2:-}";    shift 2;;
    --dry-run) DRY_RUN=1; shift;;
    -h|--help) usage; exit 0;;
    *) echo "swarm-run: unknown arg: $1" >&2; usage >&2; exit 64;;
  esac
done

die() { echo "swarm-run: $*" >&2; exit 1; }

[[ -n "$BACKEND" ]] || { usage >&2; die "--backend is required"; }
[[ -n "$ISSUE"   ]] || { usage >&2; die "--issue is required"; }

case "$BACKEND" in claude|codex) ;; *) die "--backend must be claude or codex (got: $BACKEND)";; esac
case "$MODE"    in normal|fallback|competition) ;; *) die "--mode must be normal|fallback|competition (got: $MODE)";; esac

bd_preflight_or_die "swarm-run"

HAS_JQ=0
command -v jq >/dev/null 2>&1 && HAS_JQ=1

if [[ "$BACKEND" == "codex" ]]; then
  command -v codex >/dev/null 2>&1 || die "codex not on PATH (required for --backend codex)"
fi
# Claude backend presence checked only when we're actually going to invoke it (not in dry-run).

SUPPORTED_ROLES=(agent-writer agent-spec-review agent-review agent-codex-review)
is_supported_role() {
  local r="$1" x
  for x in "${SUPPORTED_ROLES[@]}"; do [[ "$x" == "$r" ]] && return 0; done
  return 1
}

# Validate --role up front if explicitly provided — avoids masking bogus roles with bd-show errors.
if [[ -n "$ROLE" ]]; then
  is_supported_role "$ROLE" || die "role '$ROLE' not in M1 supported set: ${SUPPORTED_ROLES[*]}"
  if [[ "$ROLE" == "agent-codex-review" && "$BACKEND" == "claude" ]]; then
    die "role agent-codex-review is codex-only; re-run with --backend codex"
  fi
fi

# Fetch issue JSON (or plain fallback).
if [[ "$HAS_JQ" -eq 1 ]]; then
  ISSUE_JSON="$(bd show "$ISSUE" --json 2>/dev/null || true)"
  [[ -n "$ISSUE_JSON" ]] || die "bd show $ISSUE --json returned nothing; issue not found?"
  ASSIGNEE="$(printf '%s' "$ISSUE_JSON" | jq -r '(.assignee // .[0].assignee // empty)' 2>/dev/null || true)"
else
  ISSUE_JSON=""
  ASSIGNEE=""
fi

# Role inference if not explicitly provided.
if [[ -z "$ROLE" ]]; then
  if [[ -n "$ASSIGNEE" ]] && is_supported_role "$ASSIGNEE"; then
    ROLE="$ASSIGNEE"
  else
    die "--role omitted and could not infer a supported role from issue assignee ('${ASSIGNEE:-unknown}'). Pass --role explicitly."
  fi
fi

# agent-codex-review is codex-only.
if [[ "$ROLE" == "agent-codex-review" && "$BACKEND" == "claude" ]]; then
  die "role agent-codex-review is codex-only; re-run with --backend codex"
fi

# Model + effort matrix (plan Section 3 / 4.5).
MODEL=""; EFFORT=""
if [[ "$BACKEND" == "codex" ]]; then
  case "$ROLE" in
    agent-writer)        MODEL="gpt-5.4"; EFFORT="high";;
    agent-spec-review)   MODEL="gpt-5.4"; EFFORT="medium";;
    agent-review)        MODEL="gpt-5.4"; EFFORT="high";;
    agent-codex-review)  MODEL="gpt-5.4"; EFFORT="high";;
  esac
  if [[ "${SWARM_EFFORT_OVERRIDE:-}" == "xhigh" ]]; then EFFORT="xhigh"; fi
else
  case "$ROLE" in
    agent-writer)        MODEL="opus";   EFFORT="high";;
    agent-spec-review)   MODEL="sonnet"; EFFORT="medium";;
    agent-review)        MODEL="opus";   EFFORT="high";;
  esac
fi
[[ -n "$MODEL" && -n "$EFFORT" ]] || die "no model/effort for backend=$BACKEND role=$ROLE"

# Prompt bundle.
ROLE_DIR="$ROLES_DIR/$ROLE"
SHARED_MD="$ROLE_DIR/shared.md"
OVERLAY_MD="$ROLE_DIR/$BACKEND.md"
[[ -f "$SHARED_MD"  ]] || die "missing prompt: $SHARED_MD"
[[ -f "$OVERLAY_MD" ]] || die "missing prompt: $OVERLAY_MD"

# Trigger text from mode.
case "$MODE" in
  normal)      TRIGGER="operator choice";;
  fallback)    TRIGGER="claude rate-limit";;
  competition) TRIGGER="manual competition";;
esac
PRIOR_RUN="none"
[[ "$MODE" == "fallback" ]] && PRIOR_RUN="see prior Backend Run blocks above"

STARTED="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
T_START_EPOCH="$(date +%s)"
START_HEAD_SHA="$(git -C "${PWD}" rev-parse HEAD 2>/dev/null || true)"

# Dependency / thread context from beads.
DEP_CTX=""
if [[ "$HAS_JQ" -eq 1 ]]; then
  DEP_CTX="$(bd show "$ISSUE" --refs --thread --json 2>/dev/null || true)"
else
  DEP_CTX="$(bd show "$ISSUE" 2>/dev/null || true)"
fi

# Assemble prompt.
PROMPT="$(cat "$SHARED_MD"; printf '\n\n---\n\n'; cat "$OVERLAY_MD"; printf '\n\n---\n## Beads Issue: %s\n\n' "$ISSUE"
  if [[ -n "$ISSUE_JSON" ]]; then printf '### Issue JSON\n```json\n%s\n```\n' "$ISSUE_JSON"; fi
  printf '\n### Dependency / Thread Context\n```\n%s\n```\n' "${DEP_CTX:-<none>}"
  printf '\n### Run metadata\n- Role: %s\n- Backend: %s\n- Model: %s\n- Effort: %s\n- Mode: %s\n' \
    "$ROLE" "$BACKEND" "$MODEL" "$EFFORT" "$MODE"
)"

echo "swarm-run: rig=$BEADS_RIG backend=$BACKEND role=$ROLE model=$MODEL effort=$EFFORT mode=$MODE issue=$ISSUE dry_run=$DRY_RUN"

if [[ "$DRY_RUN" -eq 1 ]]; then
  echo "---- dry-run: would set BD_ACTOR=$ROLE and run: bd update $ISSUE --claim"
  echo "---- dry-run: would invoke $BACKEND with model=$MODEL effort=$EFFORT"
  echo "---- dry-run: prompt bytes=$(printf '%s' "$PROMPT" | wc -c | tr -d ' ')"
  echo "---- dry-run: would append Backend Run note to $ISSUE (mode=$MODE trigger=$TRIGGER)"
  echo "---- dry-run: would append telemetry row to \${CLAUDE_PLUGIN_DATA}/telemetry/runs.jsonl (telemetry write skipped in dry-run)"
  exit 0
fi

# Atomic claim.
export BD_ACTOR="$ROLE"
bd update "$ISSUE" --claim >/dev/null 2>&1 || die "bd update $ISSUE --claim failed (already claimed? wrong state?) — aborting before any notes are appended"

# Invoke backend, capture stdout.
OUT_FILE="$(mktemp -t swarm-run-out.XXXXXX)"
LOCK_FILE=""

# run_id: strict Crockford-base32 ULID shared by findings.jsonl and runs.jsonl.
_swarm_random_crockford26() {
  local alphabet="0123456789ABCDEFGHJKMNPQRSTVWXYZ" out="" i idx
  for ((i = 0; i < 26; i++)); do
    idx=$((RANDOM % 32))
    out+="${alphabet:idx:1}"
  done
  printf '%s' "$out"
}
_PY_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/py"
RUN_ID="$(PYTHONPATH="${_PY_ROOT}:${PYTHONPATH:-}" python3 -c 'from swarm_do.telemetry.ids import new_ulid; print(new_ulid())' 2>/dev/null || _swarm_random_crockford26)"

# ---------------------------------------------------------------------------
# Telemetry EXIT trap — appends one row to runs.jsonl on every exit path.
# Fail-open: ledger errors never change the pipeline exit code.
# ---------------------------------------------------------------------------
_swarm_telemetry_write() {
  local _final_rc="$1"
  local _ended _wall _hash _run_id _row _obs _tel_dir _base_sha _head_sha _diff_bytes _repo
  local _preset_name _pipeline_name _pipeline_hash _config_hash _context_py_root

  # Guard: CLAUDE_PLUGIN_DATA must be set and non-empty.
  if [[ -z "${CLAUDE_PLUGIN_DATA:-}" ]]; then
    echo "swarm-run: CLAUDE_PLUGIN_DATA unset — skipping telemetry write" >&2
    return 0
  fi

  _tel_dir="${CLAUDE_PLUGIN_DATA}/telemetry"

  {
    _ended="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    _wall=$(( $(date +%s) - T_START_EPOCH ))

    # Prompt bundle hash — fail silently to null if hash-bundle.sh is missing or fails.
    _lib_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/_lib"
    if [[ -x "${_lib_dir}/hash-bundle.sh" ]]; then
      _hash="$("${_lib_dir}/hash-bundle.sh" "$ROLE" "$BACKEND" 2>/dev/null || true)"
    else
      _hash=""
    fi
    [[ -n "$_hash" ]] || _hash="null"

    # Git metadata — best-effort, null on failure.
    # base_sha is captured at process start so writer runs preserve before/after SHAs.
    _base_sha="$START_HEAD_SHA"
    _head_sha="$(git -C "${PWD}" rev-parse HEAD 2>/dev/null || true)"
    _repo="$(git -C "${PWD}" remote get-url origin 2>/dev/null || true)"
    # diff_size_bytes measures the run's actual delta:
    #   - if backend committed (base != head), measure the committed range base..head
    #   - else fall back to the dirty working tree vs HEAD (uncommitted edits)
    if [[ -n "$_base_sha" && -n "$_head_sha" && "$_base_sha" != "$_head_sha" ]]; then
      _diff_bytes="$(git -C "${PWD}" diff --stat "${_base_sha}..${_head_sha}" 2>/dev/null | wc -c | tr -d ' ' || true)"
    else
      _diff_bytes="$(git -C "${PWD}" diff --stat HEAD 2>/dev/null | wc -c | tr -d ' ' || true)"
    fi

    # run_id: use the script-scope RUN_ID so findings.jsonl and runs.jsonl share the same run_id.
    _run_id="$RUN_ID"

    _context_py_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/py"
    _preset_name="$(PYTHONPATH="${_context_py_root}:${PYTHONPATH:-}" python3 -m swarm_do.pipeline.context preset_name 2>/dev/null || true)"
    _pipeline_name="$(PYTHONPATH="${_context_py_root}:${PYTHONPATH:-}" python3 -m swarm_do.pipeline.context pipeline_name 2>/dev/null || true)"
    _pipeline_hash="$(PYTHONPATH="${_context_py_root}:${PYTHONPATH:-}" python3 -m swarm_do.pipeline.context pipeline_hash 2>/dev/null || true)"
    _config_hash="$(PYTHONPATH="${_context_py_root}:${PYTHONPATH:-}" python3 -m swarm_do.pipeline.config_hash 2>/dev/null || true)"

    mkdir -p "$_tel_dir"

    # Build row via jq. Unobservable fields emitted as null.
    _row="$(jq -n \
      --arg run_id       "$_run_id" \
      --arg ts_start     "$STARTED" \
      --arg ts_end       "$_ended" \
      --arg backend      "$BACKEND" \
      --arg model        "$MODEL" \
      --arg effort       "$EFFORT" \
      --argjson hash     "$(if [[ "$_hash" == "null" ]]; then echo "null"; else printf '"%s"' "$_hash"; fi)" \
      --argjson config_hash "$(if [[ -n "$_config_hash" ]]; then printf '"%s"' "$_config_hash"; else echo "null"; fi)" \
      --argjson exit_code "$_final_rc" \
      --argjson wall     "$_wall" \
      --arg role         "$ROLE" \
      --arg issue_id     "$ISSUE" \
      --argjson preset_name "$(if [[ -n "$_preset_name" ]]; then printf '%s' "$_preset_name" | jq -Rs .; else echo "null"; fi)" \
      --arg pipeline_name "${_pipeline_name:-default}" \
      --argjson pipeline_hash "$(if [[ -n "$_pipeline_hash" ]]; then printf '"%s"' "$_pipeline_hash"; else echo "null"; fi)" \
      --argjson repo     "$(if [[ -n "$_repo" ]]; then printf '%s' "$_repo" | jq -Rs .; else echo "null"; fi)" \
      --argjson base_sha "$(if [[ -n "$_base_sha" ]]; then printf '"%s"' "$_base_sha"; else echo "null"; fi)" \
      --argjson head_sha "$(if [[ -n "$_head_sha" ]]; then printf '"%s"' "$_head_sha"; else echo "null"; fi)" \
      --argjson diff_size_bytes "$(if [[ "$_diff_bytes" =~ ^[0-9]+$ ]]; then printf '%s' "$_diff_bytes"; else echo "null"; fi)" \
      '{
        run_id:             $run_id,
        timestamp_start:    $ts_start,
        timestamp_end:      $ts_end,
        backend:            $backend,
        model:              $model,
        effort:             $effort,
        prompt_bundle_hash: $hash,
        config_hash:        $config_hash,
        role:               $role,
        phase_kind:         null,
        phase_complexity:   null,
        risk_tags:          null,
        issue_id:           $issue_id,
        preset_name:        $preset_name,
        pipeline_name:      $pipeline_name,
        pipeline_hash:      $pipeline_hash,
        repo:               $repo,
        base_sha:           $base_sha,
        head_sha:           $head_sha,
        diff_size_bytes:    $diff_size_bytes,
        input_tokens:       null,
        cached_input_tokens: null,
        output_tokens:      null,
        estimated_cost_usd: null,
        wall_clock_seconds: $wall,
        tool_call_count:    null,
        cap_hit:            null,
        budget_breach:      null,
        schema_ok:          true,
        exit_code:          $exit_code,
        setting_source:     null,
        writer_status:      null,
        review_verdict:     null,
        last_429_at:        null
      }')"
    printf '%s\n' "$_row" >> "${_tel_dir}/runs.jsonl"

    _obs="$(jq -n \
      --arg ts "$_ended" \
      --arg run_id "$_run_id" \
      --arg role "$ROLE" \
      --arg issue_id "$ISSUE" \
      --argjson exit_code "$_final_rc" \
      --argjson diff_size_bytes "$(if [[ "$_diff_bytes" =~ ^[0-9]+$ ]]; then printf '%s' "$_diff_bytes"; else echo "null"; fi)" \
      '{
        ts: $ts,
        run_id: $run_id,
        phase_id: $role,
        event_type: "writer_exit",
        tool: "swarm-run",
        file_paths: null,
        bead_ids: [$issue_id],
        diff_size_bytes: $diff_size_bytes,
        source: "swarm-run-exit",
        details: {exit_code: $exit_code},
        schema_ok: true
      } | del(.details)')"
    printf '%s\n' "$_obs" >> "${_tel_dir}/observations.jsonl"
  } || { echo "swarm-run: telemetry write failed (non-fatal)" >&2; true; }
}

_swarm_exit_handler() {
  local _rc="$?"
  if [[ -n "${LOCK_FILE:-}" ]]; then
    rm -f "$LOCK_FILE"
  fi
  rm -f "$OUT_FILE"
  if [[ "${DRY_RUN:-0}" -ne 1 ]]; then
    _swarm_telemetry_write "$_rc"
  fi
  exit "$_rc"
}

if [[ -n "${CLAUDE_PLUGIN_DATA:-}" ]]; then
  LOCK_DIR="${CLAUDE_PLUGIN_DATA}/in-flight"
  LOCK_FILE="${LOCK_DIR}/bd-${ISSUE}.lock"
  {
    mkdir -p "$LOCK_DIR"
    LOCK_TMP="${LOCK_FILE}.tmp.$$"
    jq -n \
      --arg issue_id "$ISSUE" \
      --arg role "$ROLE" \
      --arg backend "$BACKEND" \
      --arg model "$MODEL" \
      --arg effort "$EFFORT" \
      --arg mode "$MODE" \
      --arg started_at "$STARTED" \
      --arg repo "$(git -C "${PWD}" remote get-url origin 2>/dev/null || true)" \
      --arg worktree "$PWD" \
      --argjson pid "$$" \
      '{
        schema_version: 1,
        issue_id: $issue_id,
        role: $role,
        backend: $backend,
        model: $model,
        effort: $effort,
        mode: $mode,
        pid: $pid,
        started_at: $started_at,
        repo: ($repo | if . == "" then null else . end),
        worktree: $worktree,
        status: "running"
      }' >"$LOCK_TMP"
    mv "$LOCK_TMP" "$LOCK_FILE"
  } || { echo "swarm-run: in-flight lock write failed (non-fatal)" >&2; LOCK_FILE=""; true; }
fi

trap '_swarm_exit_handler' EXIT

if [[ "$BACKEND" == "codex" ]]; then
  if [[ "$ROLE" == "agent-codex-review" ]]; then
    REVIEW_TIMEOUT="${SWARM_CODEX_REVIEW_TIMEOUT_SECONDS:-60}"
    set +e
    printf '%s' "$PROMPT" | PYTHONPATH="${_PY_ROOT}:${PYTHONPATH:-}" python3 -m swarm_do.pipeline.timeout_exec \
      --timeout "$REVIEW_TIMEOUT" \
      --output "$OUT_FILE" \
      -- codex exec --json -m "$MODEL" -c model_reasoning_effort="\"$EFFORT\"" --skip-git-repo-check -C "$PWD"
    CODEX_REVIEW_RC=$?
    set -e
    if [[ "$CODEX_REVIEW_RC" -eq 124 ]]; then
      printf '{"status":"discarded","reason":"timeout","timeout_seconds":%s}\n' "$REVIEW_TIMEOUT" >"$OUT_FILE"
      echo "swarm-run: codex review timed out after ${REVIEW_TIMEOUT}s; discarding review and continuing" >&2
      BACKEND_RC=0
    elif [[ "$CODEX_REVIEW_RC" -ne 0 ]]; then
      echo "swarm-run: codex review failed rc=$CODEX_REVIEW_RC; discarding review and continuing" >&2
      cat "$OUT_FILE" >&2 || true
      printf '{"status":"discarded","reason":"backend_error","exit_code":%s}\n' "$CODEX_REVIEW_RC" >"$OUT_FILE"
      BACKEND_RC=0
    else
      BACKEND_RC=0
    fi
  else
    if ! printf '%s' "$PROMPT" | codex exec --json -m "$MODEL" -c model_reasoning_effort="\"$EFFORT\"" --skip-git-repo-check -C "$PWD" >"$OUT_FILE" 2>&1; then
      echo "swarm-run: codex invocation failed (see output below)" >&2
      cat "$OUT_FILE" >&2
      BACKEND_RC=1
    else
      BACKEND_RC=0
    fi
  fi
else
  # Claude backend MVP stub.
  if ! command -v claude >/dev/null 2>&1; then
    die "claude backend requires interactive Claude Code session; use /swarm-do:do from a Claude Code terminal for full hooks/skills support (exit 64)"
  fi
  if ! printf '%s' "$PROMPT" | claude -p >"$OUT_FILE" 2>&1; then
    echo "swarm-run: claude invocation failed (see output below)" >&2
    cat "$OUT_FILE" >&2
    BACKEND_RC=1
  else
    BACKEND_RC=0
  fi
fi

BACKEND_OUT="$(cat "$OUT_FILE")"

# Phase 9b: extract findings into findings.jsonl (fail-open, non-blocking).
_extractor="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/extract-phase.sh"
if [[ -x "$_extractor" && ( "$ROLE" == "agent-codex-review" || "$ROLE" == "agent-review" || "$ROLE" == "agent-code-review" ) && -f "$OUT_FILE" ]]; then
  "$_extractor" "$OUT_FILE" "$RUN_ID" "$ROLE" "${ISSUE:-unknown}" 2>&1 | sed 's/^/extract-phase: /' >&2 || true
fi

# Build and append Backend Run note block.
BLOCK="$(cat <<EOF
## Backend Run
- Backend: $BACKEND
- Model: $MODEL
- Effort: $EFFORT
- Setting source: explicit-runner
- Mode: $MODE
- Role: $ROLE
- Issue: $ISSUE
- Trigger: $TRIGGER
- Prompt bundle: swarm-do/roles/$ROLE/{shared,$BACKEND}
- Started: $STARTED
- Prior backend run: $PRIOR_RUN

$BACKEND_OUT
EOF
)"

bd update "$ISSUE" --append-notes "$BLOCK" >/dev/null || die "bd update --append-notes failed; backend output preserved at $OUT_FILE"

echo "swarm-run: appended Backend Run note to $ISSUE (backend_rc=$BACKEND_RC)"
exit "$BACKEND_RC"
