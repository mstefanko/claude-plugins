{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CodexReviewResult",
  "type": "object",
  "required": ["phase_id", "mode", "model", "effort", "findings"],
  "properties": {
    "phase_id": { "type": "string" },
    "mode": { "enum": ["A", "B"] },
    "model": { "type": "string" },
    "effort": { "enum": ["medium", "high", "xhigh"] },
    "findings": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "severity",
          "category",
          "location",
          "rationale",
          "duplicate_of_claude"
        ],
        "properties": {
          "finding_id": { "type": "string" },
          "severity": { "enum": ["critical", "warning", "info"] },
          "category": {
            "enum": [
              "types",
              "null",
              "boundary",
              "security",
              "performance",
              "design",
              "test"
            ]
          },
          "location": {
            "type": "string",
            "description": "file:line"
          },
          "rationale": { "type": "string" },
          "duplicate_of_claude": { "enum": ["yes", "no", "unknown"] }
        }
      }
    }
  }
}
