{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/work_units.schema.json#v2",
  "title": "swarm-do work-unit graph artifact",
  "description": "Descriptive schema for work_units.v1/v2. Runtime enforcement lives in pipeline.validation.schema_lint_work_units so v1-to-v2 warnings and migration rules can be expressed without oneOf.",
  "type": "object",
  "required": ["schema_version", "work_units"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "enum": [1, 2] },
    "plan_path": { "type": ["string", "null"] },
    "bd_epic_id": { "type": ["string", "null"] },
    "work_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "goal": { "type": "string" },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "context_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "files": {
            "type": "array",
            "description": "v1 field and v2 legacy alias. Runtime lint requires exactly one of files or allowed_files for v2.",
            "items": { "type": "string" }
          },
          "allowed_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "blocked_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" }
          },
          "validation_commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_results": {
            "type": "array",
            "items": { "type": "string" }
          },
          "risk_tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "handoff_notes": { "type": "string" },
          "mem_prime": { "type": "boolean" },
          "beads_id": { "type": ["string", "null"] },
          "worktree_branch": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["pending", "running", "blocked", "approved", "merged", "failed", "escalated"]
          },
          "failure_reason": {
            "type": ["string", "null"],
            "enum": [
              "budget_breach_tool_calls",
              "budget_breach_output_bytes",
              "blocked_file_violation",
              "spec_mismatch_max",
              "repeat_handoff",
              "mem_prime_failure",
              "dependency_failed",
              "other",
              null
            ]
          },
          "retry_count": { "type": "integer", "minimum": 0 },
          "handoff_count": { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
