{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/telemetry/provider_findings.v2.schema.json#v2-draft",
  "title": "swarm-do provider findings artifact v2 draft",
  "description": "Side-by-side normalized artifact for the internal swarm-review provider runner. This is a run artifact, not a telemetry JSONL ledger.",
  "type": "object",
  "required": [
    "schema_version",
    "provider",
    "command",
    "status",
    "status_reason",
    "run_id",
    "issue_id",
    "stage_id",
    "configured_providers",
    "selected_providers",
    "launched_providers",
    "schema_valid_providers",
    "provider_count",
    "min_success",
    "selection_result",
    "source_artifact_path",
    "manifest_path",
    "provider_errors",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["provider-findings.v2-draft"]
    },
    "provider": {
      "type": "string",
      "enum": ["swarm-review"]
    },
    "command": {
      "type": "string",
      "enum": ["review"]
    },
    "status": {
      "type": "string",
      "enum": ["ok", "partial", "error", "skipped"]
    },
    "status_reason": {
      "type": "string"
    },
    "run_id": {
      "type": "string",
      "pattern": "^[0-9A-Z_-]{1,64}$"
    },
    "issue_id": {
      "type": "string"
    },
    "stage_id": {
      "type": "string"
    },
    "configured_providers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "selected_providers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "launched_providers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "schema_valid_providers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Provider IDs whose outputs passed the model emission schema."
    },
    "provider_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of provider outputs that passed the emission schema."
    },
    "min_success": {
      "type": "integer",
      "minimum": 1,
      "description": "Minimum schema-valid provider output count required by the stage/policy."
    },
    "selection_result": {
      "type": "string"
    },
    "source_artifact_path": {
      "type": "string",
      "description": "Path to the normalized provider-findings artifact."
    },
    "manifest_path": {
      "type": "string"
    },
    "provider_errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["provider", "provider_error_class", "message"],
        "additionalProperties": false,
        "properties": {
          "provider": { "type": ["string", "null"] },
          "provider_error_class": { "type": ["string", "null"] },
          "message": { "type": ["string", "null"] },
          "schema_mode": { "type": ["string", "null"] },
          "sidecar_path": { "type": ["string", "null"] }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "run_id",
          "timestamp",
          "role",
          "issue_id",
          "provider",
          "provider_count",
          "detected_by",
          "agreement_ratio",
          "max_confidence",
          "consensus_score",
          "consensus_level",
          "source_artifact_path",
          "provider_error_class",
          "severity",
          "category",
          "summary",
          "short_summary",
          "file_path",
          "line_start",
          "line_end",
          "stable_finding_hash_v1",
          "duplicate_cluster_id",
          "schema_ok",
          "evidence",
          "recommendation"
        ],
        "additionalProperties": false,
        "properties": {
          "finding_id": {
            "type": "string",
            "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
          },
          "run_id": {
            "type": "string",
            "pattern": "^[0-9A-Z_-]{1,64}$"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "role": {
            "type": "string",
            "enum": ["agent-review"]
          },
          "issue_id": {
            "type": "string"
          },
          "provider": {
            "type": "string",
            "enum": ["swarm-review"]
          },
          "provider_count": {
            "type": "integer",
            "minimum": 0
          },
          "detected_by": {
            "type": "array",
            "items": { "type": "string" }
          },
          "agreement_ratio": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "max_confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "consensus_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "consensus_level": {
            "type": "string",
            "enum": ["confirmed", "needs-verification", "unverified"]
          },
          "source_artifact_path": {
            "type": "string"
          },
          "provider_error_class": {
            "type": ["string", "null"]
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "short_summary": {
            "type": "string"
          },
          "file_path": {
            "type": ["string", "null"]
          },
          "line_start": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "line_end": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "stable_finding_hash_v1": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{64}$"
          },
          "duplicate_cluster_id": {
            "type": ["string", "null"]
          },
          "schema_ok": {
            "type": "boolean"
          },
          "evidence": {
            "type": ["string", "null"]
          },
          "recommendation": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
