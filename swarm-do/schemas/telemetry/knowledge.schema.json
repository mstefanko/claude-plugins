{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/telemetry/knowledge.schema.json#v1",
  "title": "swarm-do advisory knowledge record",
  "description": "Opt-in advisory facts extracted at run close; not a resume state store.",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "phase_id",
    "file",
    "gotcha",
    "source",
    "confidence",
    "adjudication_status",
    "schema_ok"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "phase_id": {
      "type": ["string", "null"]
    },
    "file": {
      "type": "string"
    },
    "gotcha": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "adjudication_status": {
      "type": "string",
      "enum": ["pending", "accepted", "rejected", "stale"]
    },
    "regression_test_path": {
      "type": ["string", "null"]
    },
    "schema_ok": {
      "type": "boolean"
    }
  }
}
