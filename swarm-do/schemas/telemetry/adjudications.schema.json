{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/telemetry/adjudications.schema.json#v1",
  "title": "swarm-do telemetry adjudication record",
  "description": "One row per human or judge-agent adjudication of a disagreement. v1 frozen 2026-04-23. Write path implemented in a later phase.",
  "type": "object",
  "required": [
    "adjudication_id",
    "outcome_id",
    "issue_id",
    "timestamp",
    "adjudicator",
    "decision",
    "schema_ok"
  ],
  "additionalProperties": false,
  "properties": {
    "adjudication_id": {
      "type": "string",
      "description": "ULID unique adjudication identifier",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "outcome_id": {
      "type": "string",
      "description": "ULID of the parent outcomes.jsonl row",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "issue_id": {
      "type": "string",
      "description": "Beads issue identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 UTC timestamp when the adjudication was recorded"
    },
    "adjudicator": {
      "type": "string",
      "enum": ["human", "agent-analysis-judge", "agent-writer-judge"],
      "description": "Entity that performed the adjudication"
    },
    "decision": {
      "type": "string",
      "enum": ["ACCEPT_WRITER", "ACCEPT_REVIEWER", "SPLIT", "ESCALATE"],
      "description": "Adjudication decision"
    },
    "rationale": {
      "type": ["string", "null"],
      "description": "Free-text rationale for the decision. null if not provided."
    },
    "overridden_finding_ids": {
      "type": ["array", "null"],
      "items": {
        "type": "string",
        "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
      },
      "description": "ULIDs of findings.jsonl rows overridden by this adjudication. null if none."
    },
    "schema_ok": {
      "type": "boolean",
      "description": "True = writer attests the row conforms to this schema."
    }
  }
}
