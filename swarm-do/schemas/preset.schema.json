{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/preset.schema.json#v1",
  "title": "swarm-do preset",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "budget"],
  "oneOf": [
    { "required": ["pipeline"], "not": { "required": ["pipeline_inline"] } },
    { "required": ["pipeline_inline"], "not": { "required": ["pipeline"] } }
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "pipeline": { "type": "string", "minLength": 1 },
    "pipeline_inline": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pipeline_version", "name", "stages"],
      "properties": {
        "pipeline_version": { "type": "integer" },
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "parallelism": { "type": "integer", "minimum": 1, "maximum": 32 },
        "stages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        }
      }
    },
    "pipeline_inline_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "hash"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      }
    },
    "origin": { "type": "string", "enum": ["stock", "user", "experiment"] },
    "forked_from": { "type": "string", "minLength": 1 },
    "forked_from_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "generated_by": { "type": "string", "minLength": 1 },
    "routing": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["backend", "model", "effort"],
        "properties": {
          "backend": { "type": "string", "enum": ["claude", "codex"] },
          "model": { "type": "string", "minLength": 1 },
          "effort": { "type": "string", "enum": ["none", "low", "medium", "high", "xhigh"] }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_agents_per_run", "max_estimated_cost_usd", "max_wall_clock_seconds"],
      "properties": {
        "max_agents_per_run": { "type": "integer", "minimum": 1 },
        "max_estimated_cost_usd": { "type": "number", "minimum": 0 },
        "max_wall_clock_seconds": { "type": "integer", "minimum": 1 },
        "max_writer_tool_calls": { "type": "integer", "minimum": 0 },
        "max_writer_output_bytes": { "type": "integer", "minimum": 0 },
        "max_handoffs": { "type": "integer", "minimum": 0 }
      }
    },
    "decompose": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["off", "inspect", "enforce"] }
      }
    },
    "mem_prime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "type": "string", "enum": ["off", "hard_only", "on"] },
        "max_tokens": { "type": "integer", "minimum": 0 },
        "recency_days": { "type": "integer", "minimum": 0 },
        "min_relevance": { "type": "number", "minimum": 0 },
        "adapter": { "type": "string", "enum": ["dispatch_file", "local_sqlite"] }
      }
    },
    "review_providers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selection": { "type": "string", "enum": ["auto", "explicit", "off"] },
        "min_success": { "type": "integer", "minimum": 1 },
        "max_parallel": { "type": "integer", "minimum": 1, "maximum": 32 },
        "include": { "type": "array", "items": { "type": "string" } },
        "exclude": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
