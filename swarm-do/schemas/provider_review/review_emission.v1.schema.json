{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/provider_review/review_emission.v1.schema.json",
  "title": "swarm-do provider review model emission v1",
  "description": "Small model-facing schema for read-only provider review output. Swarm-owned provenance, run ids, hashes, provider counts, and consensus fields are added only after local validation.",
  "type": "object",
  "required": ["findings"],
  "additionalProperties": false,
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "severity",
          "category",
          "summary",
          "file_path",
          "line_start",
          "line_end",
          "confidence",
          "evidence",
          "recommendation"
        ],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string",
            "minLength": 1
          },
          "file_path": {
            "type": ["string", "null"]
          },
          "line_start": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "line_end": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "evidence": {
            "type": ["string", "null"]
          },
          "recommendation": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
