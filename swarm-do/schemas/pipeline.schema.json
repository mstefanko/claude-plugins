{
  "$schema": "https://json-schema.org/draft/07/schema#",
  "$id": "https://mstefanko-plugins/swarm-do/pipeline.schema.json#v1",
  "title": "swarm-do pipeline",
  "type": "object",
  "additionalProperties": false,
  "required": ["pipeline_version", "name", "stages"],
  "properties": {
    "pipeline_version": { "type": "integer", "minimum": 1 },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "origin": { "type": "string", "enum": ["stock", "user", "experiment"] },
    "forked_from": { "type": "string", "minLength": 1 },
    "forked_from_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "generated_by": { "type": "string", "minLength": 1 },
    "parallelism": { "type": "integer", "minimum": 1, "maximum": 32 },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id"],
        "oneOf": [
          {
            "required": ["agents"],
            "not": { "anyOf": [{ "required": ["fan_out"] }, { "required": ["provider"] }] }
          },
          {
            "required": ["fan_out"],
            "not": { "anyOf": [{ "required": ["agents"] }, { "required": ["provider"] }] }
          },
          {
            "required": ["provider"],
            "not": { "anyOf": [{ "required": ["agents"] }, { "required": ["fan_out"] }] }
          }
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "agents": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["role"],
              "properties": {
                "role": { "type": "string" },
                "backend": { "type": "string", "enum": ["claude", "codex"] },
                "model": { "type": "string" },
                "effort": { "type": "string", "enum": ["none", "low", "medium", "high", "xhigh"] },
                "route": { "type": "string" }
              }
            }
          },
          "fan_out": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role", "count", "variant"],
            "properties": {
              "role": { "type": "string" },
              "count": { "type": "integer", "minimum": 1, "maximum": 10 },
              "variant": { "type": "string", "enum": ["same", "prompt_variants", "models"] },
              "variants": { "type": "array", "items": { "type": "string" } },
              "routes": {
                "type": "array",
                "items": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["backend", "model", "effort"],
                      "properties": {
                        "backend": { "type": "string", "enum": ["claude", "codex"] },
                        "model": { "type": "string" },
                        "effort": { "type": "string", "enum": ["none", "low", "medium", "high", "xhigh"] }
                      }
                    }
                  ]
                }
              }
            }
          },
          "provider": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "command", "providers", "timeout_seconds"],
            "properties": {
              "type": { "type": "string", "enum": ["mco"] },
              "command": { "type": "string", "enum": ["review", "run"] },
              "providers": {
                "type": "array",
                "minItems": 1,
                "maxItems": 5,
                "items": { "type": "string", "enum": ["claude", "codex", "gemini", "opencode", "qwen"] }
              },
              "mode": { "type": "string", "enum": ["review", "debate", "divide"] },
              "strict_contract": { "type": "boolean" },
              "output": { "type": "string", "enum": ["findings"] },
              "memory": { "type": "boolean" },
              "timeout_seconds": { "type": "integer", "minimum": 1, "maximum": 86400 }
            }
          },
          "merge": {
            "type": "object",
            "additionalProperties": false,
            "required": ["strategy"],
            "properties": {
              "strategy": { "type": "string", "enum": ["synthesize", "vote"] },
              "agent": { "type": "string" }
            }
          },
          "failure_tolerance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["mode"],
            "properties": {
              "mode": { "type": "string", "enum": ["strict", "quorum", "best-effort"] },
              "min_success": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    }
  }
}
